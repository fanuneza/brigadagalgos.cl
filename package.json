{
  "name": "brigadagalgos-cl",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro check && cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "check": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro check",
    "prepare:casos": "node scripts/prepare-casos-site.mjs",
    "dog-images:check": "node scripts/normalize-dog-images.mjs --check",
    "dog-images:write": "node scripts/normalize-dog-images.mjs --write",
    "lint": "eslint . && stylelint \"src/**/*.css\" --allow-empty-input && npm run test:text",
    "lint:fix": "eslint . --fix && stylelint \"src/**/*.css\" --fix --allow-empty-input",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run && playwright test",
    "test:a11y": "playwright test tests/a11y.spec.ts",
    "test:build": "playwright test tests/build-output.spec.ts",
    "test:consent": "playwright test tests/analytics-consent.spec.ts",
    "test:source": "vitest run tests/source-hygiene.test.ts",
    "test:text": "node scripts/check-text-quality.mjs",
    "test:lighthouse": "lhci autorun",
    "test:e2e": "playwright test",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "capture:local": "playwright test --config playwright.config.ts",
    "capture:home": "playwright test --config playwright.config.ts --grep @home",
    "capture:adoptar": "playwright test --config playwright.config.ts --grep @adoptar",
    "capture:donar": "playwright test --config playwright.config.ts --grep @donar"
  },
  "dependencies": {
    "@astrojs/rss": "4.0.19",
    "@astrojs/sitemap": "3.7.3",
    "@fontsource/barlow": "^5.2.8",
    "@fontsource/barlow-condensed": "5.2.8",
    "@jdevalk/astro-seo-graph": "2.0.0",
    "@jdevalk/seo-graph-core": "0.6.2",
    "astro": "^7.0.6"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@lhci/cli": "0.15.1",
    "@playwright/test": "1.61.1",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "cross-env": "10.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-astro": "^2.1.1",
    "prettier": "^3.9.4",
    "prettier-plugin-astro": "0.14.1",
    "sharp": "^0.35.3",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "overrides": {
    "@jdevalk/astro-seo-graph": {
      "astro": "$astro"
    },
    "brace-expansion": "5.0.6",
    "devalue": "5.8.1",
    "express": "4.22.2",
    "fast-uri": "3.1.2",
    "qs": "6.15.2",
    "tmp": "0.2.5",
    "uuid": "11.1.1",
    "ws": "8.21.0",
    "yaml": "2.8.4",
    "yaml-language-server": "1.23.0"
  }
}
