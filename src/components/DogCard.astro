---
interface Dog {
  id: string;
  name: string;
  sex: 'Macho' | 'Hembra';
  age: string;
  weight: string;
  personality: string;
  image: string;
}

interface Props {
  dog: Dog;
  waHref: string;
  [key: string]: unknown;
}

const { dog, waHref, ...rest } = Astro.props;
---

<article class="dog-card" {...rest}>
  <div class="dog-card__photo-wrapper">
    <img
      src={dog.image}
      alt={`Foto de ${dog.name}`}
      class="dog-card__photo"
      width="400"
      height="400"
      loading="lazy"
      decoding="async"
    />
  </div>
  <div class="dog-card__body">
    <h2 class="dog-card__name">{dog.name}</h2>
    <div class="dog-card__chips">
      <span class="chip chip--sex">{dog.sex}</span>
      <span class="chip chip--age">{dog.age}</span>
      <span class="chip chip--weight">{dog.weight}</span>
    </div>
    <p class="dog-card__personality">{dog.personality}</p>
    <a
      href={waHref}
      class="btn btn--primary dog-card__cta"
      target="_blank"
      rel="noopener noreferrer"
    >
      Me interesa {dog.name}
    </a>
  </div>
</article>
