---
import { SITE } from "../config/site.ts";
import helpCardsCss from "../styles/components/help-cards.css?raw";
---

<style is:inline set:html={helpCardsCss}></style>

<section class="section-padding help-cards" data-track-section="help_cards">
  <div class="container">
    <div class="help-cards__header">
      <p class="help-cards__eyebrow">C&oacute;mo ayudar</p>
      <h2 class="help-cards__heading">Tres formas de apoyar nuestra labor.</h2>
    </div>

    <div class="help-cards__grid">
      <article class="card">
        <div class="card__icon card__icon--primary" aria-hidden="true">
          <img src="/icons/adoptar.svg" alt="" aria-hidden="true" class="card__icon-image" width="24" height="24" loading="lazy" decoding="async" />
        </div>
        <h3 class="card__title">Adoptar</h3>
        <p class="card__desc">
          Conoce los galgos disponibles y empieza el proceso. Te acompa&ntilde;amos en cada paso.
        </p>
        <a
          href="/adoptar/"
          class="card__cta"
          data-track-event="cta_click"
          data-track-label="Ver galgos"
          data-track-location="help_cards"
          data-track-destination="/adoptar/"
          data-track-category="adoption"
        >
          Ver galgos &rarr;
        </a>
      </article>

      <article class="card">
        <div class="card__icon card__icon--secondary" aria-hidden="true">
          <img src="/icons/hogar-temporal.svg" alt="" aria-hidden="true" class="card__icon-image" width="24" height="24" loading="lazy" decoding="async" />
        </div>
        <h3 class="card__title">Hogar temporal</h3>
        <p class="card__desc">
          Recibe un galgo en tu casa mientras encuentra hogar definitivo. Evaluamos contigo tiempos, seguridad y
          convivencia.
        </p>
        <a
          href="/hogar-temporal/"
          class="card__cta"
          data-track-event="cta_click"
          data-track-label="Quiero postular"
          data-track-location="help_cards"
          data-track-destination="/hogar-temporal/"
          data-track-category="foster"
        >
          Quiero postular &rarr;
        </a>
      </article>

      <article class="card">
        <div class="card__icon card__icon--warm" aria-hidden="true">
          <img src="/icons/donar.svg" alt="" aria-hidden="true" class="card__icon-image" width="24" height="24" loading="lazy" decoding="async" />
        </div>
        <h3 class="card__title">Donar</h3>
        <p class="card__desc">
          Tu aporte ayuda a sostener comida, atenci&oacute;n veterinaria, traslados y acogida mientras esperan familia.
        </p>
        <a
          href={SITE.esponsor}
          target="_blank"
          rel="noopener noreferrer"
          class="card__cta"
          data-track-event="cta_click"
          data-track-label="Quiero donar"
          data-track-location="help_cards"
          data-track-destination={SITE.esponsor}
          data-track-category="donation"
          data-track-outbound="true"
        >
          Quiero donar &rarr;
        </a>
      </article>
    </div>
  </div>
</section>
