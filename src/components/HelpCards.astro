---
import { SITE } from '../config/site.ts';
---

<section class="section-padding help-cards">
  <div class="container">

    <div class="help-cards__header">
      <p class="help-cards__eyebrow">Cómo ayudar</p>
      <h2 class="help-cards__heading">Tres formas de ayudar.</h2>
    </div>

    <div class="help-cards__grid">

      <article class="card">
        <div class="card__icon card__icon--primary" aria-hidden="true">
          <!-- Paw icon -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <ellipse cx="12" cy="17" rx="5" ry="4" stroke="white" stroke-width="2"/>
            <ellipse cx="5" cy="12" rx="2" ry="3" stroke="white" stroke-width="2"/>
            <ellipse cx="19" cy="12" rx="2" ry="3" stroke="white" stroke-width="2"/>
            <ellipse cx="8.5" cy="8" rx="2" ry="2.5" stroke="white" stroke-width="2"/>
            <ellipse cx="15.5" cy="8" rx="2" ry="2.5" stroke="white" stroke-width="2"/>
          </svg>
        </div>
        <h3 class="card__title">Adoptar</h3>
        <p class="card__desc">Conoce los galgos disponibles y empieza el proceso. Te acompañamos en cada paso.</p>
        <a href="/adoptar" class="card__cta">Ver galgos &rarr;</a>
      </article>

      <article class="card">
        <div class="card__icon card__icon--secondary" aria-hidden="true">
          <!-- Home icon -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M3 9.5L12 3l9 6.5V20a1 1 0 0 1-1 1H4a1 1 0 0 1-1-1V9.5z" stroke="white" stroke-width="2" stroke-linejoin="round"/>
            <path d="M9 21V12h6v9" stroke="white" stroke-width="2" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card__title">Hogar temporal</h3>
        <p class="card__desc">Recibe un galgo en tu casa mientras encuentra hogar definitivo. No necesitas experiencia previa.</p>
        <a href="/hogar-temporal" class="card__cta">Quiero postular &rarr;</a>
      </article>

      <article class="card">
        <div class="card__icon card__icon--warm" aria-hidden="true">
          <!-- Heart icon — charcoal stroke because orange icon bg -->
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78L12 21.23l8.84-8.84a5.5 5.5 0 0 0 0-7.78z" stroke="#1F2328" stroke-width="2" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="card__title">Donar</h3>
        <p class="card__desc">Tu aporte cubre comida, vacunas y traslados. El 100% va a los galgos. Nadie cobra sueldo.</p>
        <a href={SITE.esponsor} target="_blank" rel="noopener noreferrer" class="card__cta">Quiero donar &rarr;</a>
      </article>

    </div>
  </div>
</section>
