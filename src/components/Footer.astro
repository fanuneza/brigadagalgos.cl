---
import { SITE } from '../config/site.ts';
---

<footer class="footer">
  <div class="container footer__grid">

    <div class="footer__brand">
      <a href="/" aria-label="Brigada Galgos — inicio">
        <img
          src="/images/brigada-galgos-logo.png"
          alt="Brigada Galgos"
          class="footer__logo"
          width="160"
          height="48"
          loading="lazy"
        />
      </a>
      <p class="footer__tagline">Rescatamos galgos en todo Chile y los acompañamos hasta su hogar definitivo.</p>
    </div>

    <div class="footer__contact">
      <h3 class="footer__section-title">Contacto</h3>
      <ul class="footer__list">
        <li>
          <a href={`mailto:${SITE.email}`} class="footer__link">
            {SITE.email}
          </a>
        </li>
        <li>
          <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="footer__link">
            WhatsApp {SITE.whatsappPhone}
          </a>
        </li>
      </ul>
      <div class="footer__social">
        <a href={SITE.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="footer__social-link">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" stroke="currentColor" stroke-width="2"/>
            <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="2"/>
            <circle cx="17.5" cy="6.5" r="1.5" fill="currentColor"/>
          </svg>
        </a>
        <a href={SITE.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="footer__social-link">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer__nav">
      <h3 class="footer__section-title">Navegar</h3>
      <ul class="footer__list">
        <li><a href="/adoptar" class="footer__link">Adoptar</a></li>
        <li><a href="/hogar-temporal" class="footer__link">Hogar temporal</a></li>
        <li><a href="/donar" class="footer__link">Donar</a></li>
        <li><a href="/contacto" class="footer__link">Contacto</a></li>
      </ul>
    </div>

  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <p class="footer__copy">
        &copy; 2026 Fundación Brigada Galgos &middot; RUT <span class="pendiente">[PENDIENTE: RUT]</span>
      </p>
      <a
        href={SITE.esponsor}
        target="_blank"
        rel="noopener noreferrer"
        class="btn btn--secondary footer__esponsor-btn"
      >Quiero donar en eSponsor</a>
    </div>
  </div>
</footer>
