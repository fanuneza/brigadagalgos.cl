---
import { SITE } from "../config/site.ts";
import footerCss from "../styles/components/footer.css?raw";
---

<style is:inline set:html={footerCss}></style>

<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <a href="/" class="footer__brand-link">
        <img
          src="/images/brigada-galgos-logo.png"
          alt="Brigada Galgos"
          class="footer__logo"
          width="160"
          height="48"
          loading="lazy"
        />
        <span class="footer__brand-name">Fundacion<br />Brigada Galgos</span>
      </a>
      <p class="footer__tagline">Rescatamos galgos en todo Chile y los acompanamos hasta su hogar definitivo.</p>
    </div>

    <div class="footer__contact">
      <h3 class="footer__section-title">Contacto</h3>
      <ul class="footer__list">
        <li>
          <a href={`mailto:${SITE.email}`} class="footer__link">
            {SITE.email}
          </a>
        </li>
        <li>
          <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="footer__link">
            WhatsApp {SITE.whatsappPhone}
          </a>
        </li>
      </ul>
      <div class="footer__social">
        <a
          href={SITE.instagram}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="footer__social-link"
          data-external-indicator="off"
        >
          <img src="/icons/instagram.svg" alt="" aria-hidden="true" class="footer__social-icon" />
        </a>
        <a
          href={SITE.facebook}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="footer__social-link"
          data-external-indicator="off"
        >
          <img src="/icons/facebook.svg" alt="" aria-hidden="true" class="footer__social-icon" />
        </a>
      </div>
    </div>

    <div class="footer__nav">
      <h3 class="footer__section-title">Navegar</h3>
      <ul class="footer__list">
        <li><a href="/adoptar/" class="footer__link">Adoptar</a></li>
        <li><a href="/hogar-temporal/" class="footer__link">Hogar temporal</a></li>
        <li><a href="/colaboradores/" class="footer__link">Colaboradores</a></li>
        <li><a href="/donar/" class="footer__link">Donar</a></li>
        <li><a href="/contacto/" class="footer__link">Contacto</a></li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <div class="footer__copy">
        <p>&copy; 2026 Fundacion Brigada Galgos &middot; RUT 65.132.425-4</p>
        <p>
          Sitio web desarrollado con
          <img src="/icons/heart.svg" alt="" aria-hidden="true" class="footer__heart-icon" />
          por
          <a
            href="https://agenciachucao.cl/?utm_source=brigadagalgos.cl&utm_medium=referral&utm_campaign=credit_footer"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Abrir el sitio de Agencia Chucao en una pestana nueva">agencia chucao</a
          >
        </p>
      </div>
      <a href={SITE.esponsor} target="_blank" rel="noopener noreferrer" class="btn btn--secondary footer__esponsor-btn"
        >Quiero donar en eSponsor</a
      >
    </div>
  </div>
</footer>
