---
import { SITE } from "../config/site.ts";
import "../styles/components/footer.css";

const currentYear = new Date().getFullYear();
---


<footer class="footer">
  <div class="container footer__grid">
    <div class="footer__brand">
      <a href="/" class="footer__brand-link">
        <img
          src="/images/brigada-galgos-logo.webp"
          alt="Logo de Brigada Galgos del footer"
          aria-hidden="true"
          class="footer__logo"
          width="40"
          height="40"
          loading="lazy"
          decoding="async"
        />
        <span class="footer__brand-name">Fundación<br />Brigada Galgos</span>
      </a>
      <div class="footer__tagline">
        <p>Rescatamos galgos en todo Chile y los acompañamos hasta su hogar definitivo.</p>
        <p class="footer__brand-legal">&copy; {currentYear} Fundación Brigada Galgos</p>
        <p class="footer__brand-legal">RUT 65.132.425-4</p>
      </div>
    </div>

    <div class="footer__contact">
      <h3 class="footer__section-title">Contacto</h3>
      <ul class="footer__list">
        <li>
          <a href={`mailto:${SITE.email}`} class="footer__link">
            {SITE.email}
          </a>
        </li>
        <li>
          <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" class="footer__link">
            WhatsApp {SITE.whatsappPhone}
          </a>
        </li>
      </ul>
      <div class="footer__social">
        <a
          href={SITE.instagram}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
          class="footer__social-link"
          data-external-indicator="off"
        >
          <img
            src="/icons/instagram.svg"
            alt=""
            aria-hidden="true"
            class="footer__social-icon"
            width="36"
            height="36"
            loading="lazy"
            decoding="async"
          />
        </a>
        <a
          href={SITE.facebook}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
          class="footer__social-link"
          data-external-indicator="off"
        >
          <img
            src="/icons/facebook.svg"
            alt=""
            aria-hidden="true"
            class="footer__social-icon"
            width="36"
            height="36"
            loading="lazy"
            decoding="async"
          />
        </a>
      </div>
    </div>

    <div class="footer__nav">
      <h3 class="footer__section-title">Navegar</h3>
      <ul class="footer__list">
        <li><a href="/adoptar/" class="footer__link">Adoptar</a></li>
        <li><a href="/hogar-temporal/" class="footer__link">Hogar temporal</a></li>
        <li><a href="/por-que-galgos/" class="footer__link">Por qué galgos</a></li>
        <li><a href="/preguntas-frecuentes/" class="footer__link">Preguntas frecuentes</a></li>
        <li><a href="/colaboradores/" class="footer__link">Colaboradores</a></li>
        <li><a href="/contacto/" class="footer__link">Contacto</a></li>
      </ul>
    </div>
  </div>

  <div class="footer__bottom">
    <div class="container footer__bottom-inner">
      <div class="footer__copy">
        <p>
          Sitio web desarrollado con
          <img
            src="/icons/heart.svg"
            alt=""
            aria-hidden="true"
            class="footer__heart-icon"
            width="16"
            height="16"
            loading="lazy"
            decoding="async"
          />
          por
          <a
            href="https://agenciachucao.cl/?utm_source=brigadagalgos.cl&utm_medium=referral&utm_campaign=credit_footer"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Abrir el sitio de Agencia Chucao en una pestaña nueva">agencia chucao</a
          >
        </p>
      </div>
      <div class="footer__legal">
        <a href="/politica-de-cookies/" class="footer__legal-link">Política de cookies</a>
        <button type="button" class="footer__legal-button" id="cookie-manage-btn"
          >Gestionar preferencias de cookies</button
        >
      </div>
      <a
        href="/donar/"
        class="btn btn--secondary footer__esponsor-btn"
        data-track-event="cta_click"
        data-track-label="Voy a apoyar un galgo"
        data-track-location="footer"
        data-track-destination="/donar/"
        data-track-category="donation"
      >
        Voy a apoyar un galgo
      </a>
    </div>
  </div>
</footer>
