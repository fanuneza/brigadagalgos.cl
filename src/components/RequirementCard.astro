---
import requirementCardCss from "../styles/components/requirement-card.css?raw";

interface Props {
  icon: string;
  title: string;
  body: string;
  tone?: "primary" | "secondary" | "warm";
}

const { icon, title, body, tone = "primary" } = Astro.props;
---

<style is:inline set:html={requirementCardCss}></style>

<article class="req-card">
  <span class={`req-card__icon req-card__icon--${tone}`} aria-hidden="true">
    <img
      src={icon}
      alt=""
      aria-hidden="true"
      class="req-card__icon-image"
      width="24"
      height="24"
      loading="lazy"
      decoding="async"
    />
  </span>
  <p class="req-card__title">{title}</p>
  <p class="req-card__body">{body}</p>
</article>
