---
import { getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import portraitSrc from "../assets/images/hero-portrait.webp";
import landscapeSrc from "../assets/images/hero-landscape.webp";
import heroCss from "../styles/components/hero.css?raw";

const portraitWidths = [360, 540, 720];
const landscapeWidths = [560, 840, 1120];

async function buildSrcSet(src: ImageMetadata, format: "avif" | "webp", widths: number[]) {
  const variants = await Promise.all(widths.map((width) => getImage({ src, format, width })));
  return variants.map((variant) => `${variant.src} ${variant.options.width}w`).join(", ");
}

const pAvifSrcSet = await buildSrcSet(portraitSrc, "avif", portraitWidths);
const pWebpSrcSet = await buildSrcSet(portraitSrc, "webp", portraitWidths);
const lAvifSrcSet = await buildSrcSet(landscapeSrc, "avif", landscapeWidths);
const lWebpSrcSet = await buildSrcSet(landscapeSrc, "webp", landscapeWidths);
const pFallback = await getImage({ src: portraitSrc, format: "webp", width: 540 });
---

<style is:inline set:html={heroCss}></style>

<section class="hero section-padding">
  <div class="container hero__grid">
    <div class="hero__text">
      <h1>Rescatamos, rehabilitamos y reubicamos galgos en Chile.</h1>
      <p class="hero__lead">
        Son tranquilos en casa, se adaptan a departamentos y agradecen profundamente. Son el corazón silencioso de la
        familia.
      </p>
      <div class="hero__ctas">
        <a href="/adoptar/" class="btn btn--primary">Quiero adoptar</a>
        <a href="/hogar-temporal/" class="btn btn--secondary">Puedo ser hogar temporal</a>
        <a href="/donar/" class="btn btn--secondary">Voy a apoyar</a>
      </div>
    </div>

    <picture class="hero__photo">
      <source
        media="(min-width: 1024px)"
        srcset={lAvifSrcSet}
        sizes="(min-width: 1200px) 528px, calc(50vw - 72px)"
        type="image/avif"
      />
      <source
        media="(min-width: 1024px)"
        srcset={lWebpSrcSet}
        sizes="(min-width: 1200px) 528px, calc(50vw - 72px)"
        type="image/webp"
      />
      <source srcset={pAvifSrcSet} sizes="calc(100vw - 48px)" type="image/avif" />
      <img
        srcset={pWebpSrcSet}
        sizes="calc(100vw - 48px)"
        src={pFallback.src}
        alt="Galgo rescatado mirando hacia adelante"
        class="hero__img"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width={portraitSrc.width}
        height={portraitSrc.height}
      />
    </picture>
  </div>
</section>
