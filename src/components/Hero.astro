---
---

<section class="hero section-padding">
  <div class="container hero__grid">
    <div class="hero__text">
      <h1>Rescatamos galgos en todo Chile.</h1>
      <p class="hero__lead">Sacamos a galgos del abandono, los curamos
        y buscamos la familia que se merecen.</p>
      <div class="hero__ctas">
        <a href="/adoptar" class="btn btn--primary">Adoptar</a>
        <a href="/hogar-temporal" class="btn btn--secondary">Postular</a>
        <a href="/donar" class="btn btn--secondary">Donar</a>
      </div>
    </div>

    <picture class="hero__photo">
      <source
        media="(min-width: 1024px)"
        srcset="/images/hero-landscape.webp"
        type="image/webp"
      />
      <img
        src="/images/hero-portrait.webp"
        alt="Galgo rescatado mirando hacia adelante"
        class="hero__img"
        loading="eager"
        decoding="async"
        fetchpriority="high"
        width="800"
        height="1000"
      />
    </picture>
  </div>
</section>
