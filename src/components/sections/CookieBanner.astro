---
import "../../styles/components/cookie-banner.css";
---

<div class="cookie-banner" id="cookie-banner" role="region" aria-live="polite" aria-label="Aviso de cookies">
  <div class="cookie-banner__inner container">
    <p class="cookie-banner__text">
      Usamos cookies de analítica para entender cómo se usa el sitio y mejorarlo. Puedes aceptar o rechazar su uso. <a
        href="/politica-de-cookies/"
        class="cookie-banner__link">Política de cookies</a
      >
    </p>
    <div class="cookie-banner__actions">
      <button class="btn btn--primary cookie-banner__button" id="cookie-accept" type="button">Aceptar</button>
      <button class="btn btn--ghost cookie-banner__button" id="cookie-reject" type="button">Rechazar</button>
    </div>
  </div>
</div>
