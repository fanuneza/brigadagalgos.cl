---
import WhatsAppLink from "../../components/WhatsAppLink.astro";
import TrackedLink from "../../components/TrackedLink.astro";

const steps = [
  {
    number: "1",
    title: "Completa el formulario",
    body: "Usamos un formulario de Google donde nos cuentas tu disponibilidad, tu casa, quiénes viven contigo y tu experiencia con perros. Si tienes dudas, escríbenos primero: no esperamos que tengas todo claro desde el primer mensaje.",
  },
  {
    number: "2",
    title: "Cambia la espera del galgo",
    body: "El hogar temporal es temporal para ti y cambia por completo la espera del galgo. Nos permite conocer su rutina, cuidarlo mejor y preparar una adopción responsable.",
  },
  {
    number: "3",
    title: "Coordinamos durante la acogida",
    body: "Durante la acogida coordinamos contigo por WhatsApp y compartimos novedades cuando hay avances relevantes, sin prometer una frecuencia fija.",
  },
];
---

<section id="form" class="section-padding">
  <div class="container container--narrow">
    <p class="eyebrow">POSTULAR</p>
    <h2>Completa tu postulación</h2>

    <ol class="foster-cta__steps" role="list">
      {
        steps.map((step) => (
          <li class="foster-cta__step">
            <span class="foster-cta__step-number" aria-hidden="true">
              {step.number}
            </span>
            <div class="foster-cta__step-body">
              <h3 class="foster-cta__step-title">{step.title}</h3>
              <p>{step.body}</p>
            </div>
          </li>
        ))
      }
    </ol>

    <div class="foster-cta cta-card">
      <TrackedLink
        href="https://forms.gle/3YHPo8KKnCiySbCo6"
        class="btn btn--primary"
        newTab
        trackEvent="foster_apply_click"
        trackLabel="Postula aquí - Foster Application"
        trackLocation="foster_cta"
        trackDestination="https://forms.gle/3YHPo8KKnCiySbCo6"
        trackCategory="foster"
        trackOutbound
        data-application-form-url="https://forms.gle/3YHPo8KKnCiySbCo6"
      >
        Puedo ser hogar temporal <span class="sr-only"> (abre en una nueva pestaña)</span>
      </TrackedLink>
      <p class="foster-cta__fallback">
        ¿Prefieres hablar primero?{" "}
        <WhatsAppLink
          text="Hola, quisiera ser hogar temporal"
          location="foster_cta"
          label="Escríbenos directo por WhatsApp - Foster Fallback"
          class="text-link foster-cta__whatsapp-link"
        >
          Escríbenos directo por WhatsApp
        </WhatsAppLink>
      </p>
      <p class="cta-card__aside">
        Antes de postular también puedes{" "}
        <a href="/preguntas-frecuentes/">revisar las preguntas frecuentes</a>.
      </p>
    </div>
  </div>
</section>
