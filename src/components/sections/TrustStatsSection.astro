---
import { getCollection, type CollectionEntry } from "astro:content";

const rawDogsList: CollectionEntry<"adoption-dogs">[] = await getCollection("adoption-dogs");
const adoptionDogCount = rawDogsList.filter((dog) => dog.data.active !== false).length;
const yearsActive = Math.max(new Date().getFullYear() - 2023, 1);
---

<section class="section-padding trust-stats">
  <div class="container">
    <p class="eyebrow">COMPROMISO</p>
    <h2>Los números que nos avalan</h2>
    <div class="trust-stats__grid">
      <div class="stat-card">
        <p class="stat-card__value stat-card__value--cyan">{yearsActive}+</p>
        <h3 class="stat-card__label">años activas</h3>
        <p class="stat-card__body">Nos formamos en 2023 desde experiencia previa rescatando y adoptando galgos.</p>
      </div>
      <div class="stat-card">
        <p class="stat-card__value stat-card__value--magenta">6</p>
        <h3 class="stat-card__label">mujeres coordinando</h3>
        <p class="stat-card__body">
          Sostenemos rescates, hogares temporales, adopciones y seguimiento con una red de apoyo.
        </p>
      </div>
      <div class="stat-card">
        <p class="stat-card__value stat-card__value--orange">100+</p>
        <h3 class="stat-card__label">rescates</h3>
        <p class="stat-card__body">
          Cada historia muestra un galgo que tuvo acompañamiento hasta llegar a una nueva vida.
        </p>
      </div>
      <div class="stat-card">
        <p class="stat-card__value stat-card__value--green">{adoptionDogCount}</p>
        <h3 class="stat-card__label">galgos en adopción</h3>
        <p class="stat-card__body">
          Presentamos nombres, fotos y detalles para que cada postulación parta con información real.
        </p>
      </div>
    </div>
  </div>
</section>
