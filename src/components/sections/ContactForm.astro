---

---

<section class="section-padding">
  <div class="container container--narrow">
    <p class="eyebrow">ESCRÍBENOS</p>
    <h2>O envíanos un mensaje</h2>
    <p class="section-body">
      Cuéntanos si quieres adoptar, ser hogar temporal, apoyar con una donación o hacer otra pregunta. Si falta
      información, la revisamos contigo después.
    </p>

    <form
      class="form"
      data-form
      id="contact-form"
      novalidate
      toolname="enviar_mensaje_contacto"
      tooldescription="Envía un mensaje de contacto a la fundación Brigada Galgos para consultas sobre adopción, hogares temporales, donaciones o consultas generales."
    >
      <input type="hidden" name="access_key" value="ef1e3d39-d9cf-4778-84c4-91e619f1cfeb" />
      <input type="hidden" name="form_id" value="ef1e3d39-d9cf-4778-84c4-91e619f1cfeb" />
      <input type="hidden" name="subject" value="Nuevo mensaje desde brigadagalgos.cl" />
      <input
        type="checkbox"
        name="botcheck"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
        class="form__honeypot"
      />

      <div class="field">
        <label for="nombre">Nombre</label>
        <input
          type="text"
          id="nombre"
          name="nombre"
          autocomplete="name"
          required
          toolparamdescription="Nombre completo de la persona que envía el mensaje."
        />
      </div>

      <div class="field">
        <label for="email">Correo</label>
        <input
          type="email"
          id="email"
          name="email"
          autocomplete="email"
          required
          toolparamdescription="Dirección de correo electrónico del remitente."
        />
      </div>

      <div class="field">
        <label for="asunto">Asunto</label>
        <select
          id="asunto"
          name="asunto"
          required
          toolparamdescription="El tema o motivo de la consulta (Adopción, Hogar temporal, Donación, Prensa o Consulta general)."
        >
          <option value="">Selecciona el asunto</option>
          <option value="Adopción">Adopción</option>
          <option value="Hogar temporal">Hogar temporal</option>
          <option value="Donación">Donación</option>
          <option value="Prensa">Prensa</option>
          <option value="Consulta general">Consulta general</option>
        </select>
      </div>

      <div class="field">
        <label for="mensaje">Mensaje</label>
        <textarea
          id="mensaje"
          name="mensaje"
          rows="4"
          placeholder="¿En qué podemos ayudarte?"
          required
          toolparamdescription="Detalle del mensaje, consulta o pregunta."></textarea>
      </div>

      <button type="submit" class="btn btn--primary form__submit">
        <span class="form__submit-label">Enviar mensaje</span>
        <span class="form__submit-spinner" hidden aria-hidden="true">Enviando…</span>
      </button>
    </form>

    <div class="form__success" hidden data-form-success id="contact-success">
      <p class="form__success-title">¡Recibimos tu mensaje!</p>
      <p>Te responderemos al correo que nos dejaste.</p>
      <a href="/" class="btn btn--secondary" data-astro-prefetch>Volver al inicio</a>
    </div>
  </div>
</section>

<script>
  import "../../scripts/form";
</script>
