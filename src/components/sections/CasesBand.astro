---
import SharedPhotoGallery from "../SharedPhotoGallery.astro";
import type { StoryDogSummary } from "../../utils/dog-content";
import InstagramLink from "../InstagramLink.astro";
import { getInstagramHandleLabel } from "../../utils/instagram";

interface Props {
  cases: StoryDogSummary[];
}

const { cases } = Astro.props;
---

<section class="section-padding why-galgos__cases-band">
  <div class="container why-galgos__cases-shell">
    <div class="why-galgos__cases-intro">
      <p class="eyebrow">CASOS REALES</p>
      <h2>Por eso insistimos con ellos</h2>
      <p class="why-galgos__cases-lead">
        No hablamos en abstracto. Cada recuperación vuelve más concreta la razón de esta brigada.
      </p>
    </div>

    <div class="stories__grid why-galgos__stories-grid">
      {
        cases.map((dog, caseIndex) => (
          <article
            class="story-card story-card--compact"
            data-story-card
            data-story-id={dog.id}
            data-story-name={dog.name}
            data-story-location="why_galgos"
          >
            <SharedPhotoGallery
              name={dog.name}
              photos={dog.photos}
              id={dog.id}
              loadingPriority={caseIndex < 2 ? "eager" : "lazy"}
            />
            <div
              class="story-card__body"
              data-track-event="story_click"
              data-track-label={dog.name}
              data-track-location="why_galgos"
              data-story-id={dog.id}
              data-story-name={dog.name}
            >
              <p class="story-card__name">{dog.name}</p>
              <p class="story-card__quote">{dog.cardStory}</p>
              {dog.instagramUrl && (
                <InstagramLink
                  url={dog.instagramUrl}
                  name={dog.name}
                  location="why_galgos"
                  class="story-card__social dog-social-link"
                >
                  <img src="/icons/instagram.svg" alt="" aria-hidden="true" />
                  <span>{getInstagramHandleLabel(dog.instagramUrl)}</span>
                </InstagramLink>
              )}
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
