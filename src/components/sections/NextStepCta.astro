---
import TrackedLink from "../../components/TrackedLink.astro";

interface Props {
  location?: string;
}

const { location = "why_galgos" } = Astro.props;
---

<section class="section-padding end-cta">
  <div class="container container--narrow">
    <div class="cta-card cta-card--end">
      <p class="eyebrow">SIGUIENTE PASO</p>
      <h2>Si un galgo te hace sentido, conversemos</h2>
      <p>
        Si crees que tu casa podría ser un buen lugar para uno de ellos, te acompañamos desde el primer mensaje. Y si
        todavía no es el momento de adoptar, un hogar temporal también puede cambiar por completo la historia de un
        rescate.
      </p>
      <div class="cta-card__actions">
        <TrackedLink
          href="/adoptar/"
          class="btn btn--primary"
          trackEvent="cta_click"
          trackLabel="Quiero adoptar"
          trackLocation={location}
          trackDestination="/adoptar/"
          trackCategory="adoption"
        >
          Quiero adoptar
        </TrackedLink>
        <TrackedLink
          href="/hogar-temporal/"
          class="btn btn--secondary"
          trackEvent="cta_click"
          trackLabel="Puedo ser hogar temporal"
          trackLocation={location}
          trackDestination="/hogar-temporal/"
          trackCategory="foster"
        >
          Puedo ser hogar temporal
        </TrackedLink>
      </div>
    </div>
  </div>
</section>
