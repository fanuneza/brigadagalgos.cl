---
import WhatsAppLink from "../../components/WhatsAppLink.astro";

const ways = [
  {
    title: "Donación de materiales",
    body: "Comida, mantas o medicamentos.",
    tone: "primary",
  },
  {
    title: "Servicios profesionales",
    body: "Veterinarios, transporte, fotografía.",
    tone: "secondary",
  },
  {
    title: "Difusión de casos",
    body: "Comparte nuestras publicaciones a traves de tus redes sociales.",
    tone: "warm",
  },
];
---

<section class="section-padding tail-cta end-cta">
  <div class="container container--narrow">
    <div class="cta-card cta-card--end">
      <p class="eyebrow">OTRAS FORMAS DE AYUDAR</p>
      <h2>También nos puedes apoyar así</h2>

      <ul class="tail-cta__list" role="list">
        {
          ways.map((way) => (
            <li class="tail-cta__item">
              <span class={`tail-cta__dot tail-cta__dot--${way.tone}`} aria-hidden="true" />
              <div>
                <h3 class="tail-cta__item-title">{way.title}</h3>
                <p>{way.body}</p>
              </div>
            </li>
          ))
        }
      </ul>

      <div class="cta-card__actions">
        <WhatsAppLink
          text="Hola, quiero ayudar de otra forma"
          location="help_tail_cta"
          label="Coordina por WhatsApp - Help Tail CTA"
          class="btn btn--primary"
        >
          Coordina por WhatsApp <span class="sr-only"> (abre en una nueva pestaña)</span>
        </WhatsAppLink>
      </div>
    </div>
  </div>
</section>
