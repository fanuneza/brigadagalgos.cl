---
import { SITE } from "../../config/site.ts";
import TrackedLink from "../../components/TrackedLink.astro";

const suggestedAmounts = [
  {
    amount: "$35.000",
    label: "Vacunas anuales",
    detail: "Permite cubrir el esquema básico de vacunas para mantener protegido a un galgo rescatado.",
  },
  {
    amount: "$50.000",
    label: "Alimento mensual",
    detail: "Asegura el alimento balanceado de un galgo rescatado durante un mes entero.",
  },
  {
    amount: "$60.000",
    label: "Consulta de urgencia",
    detail: "Financia una consulta veterinaria de urgencia ante cualquier accidente o imprevisto de salud.",
  },
  {
    amount: "$200.000",
    label: "Tratamientos complejos",
    detail:
      "Con este monto o más nos ayudas a costear exámenes de sangre, ecografías, radiografías y consultas de especialidad.",
  },
];
---

<section class="section-padding">
  <div class="container">
    <h2 class="sr-only">Formas de donar</h2>
    <p class="donation-intro">
      No hay un monto único correcto. Elige una cantidad que puedas sostener y nosotros la destinamos a las necesidades
      reales de los galgos: salud, comida, traslados, implementos y acompañamiento.
    </p>
    <div class="donation-amounts" aria-label="Montos sugeridos">
      {
        suggestedAmounts.map((item) => (
          <div class="donation-amount">
            <p class="donation-amount__value">{item.amount}</p>
            <p class="donation-amount__label">{item.label}</p>
            <p>{item.detail}</p>
          </div>
        ))
      }
    </div>
    <div class="donation-cards">
      <div class="donation-card donation-card--transferencia" id="datos-transferencia">
        <span class="chip chip--recommended">Recomendado</span>
        <h3 class="donation-card__heading">TRANSFERENCIA ÚNICA</h3>
        <p class="donation-card__subtitle">O transferencia recurrente, si lo prefieres.</p>
        <div class="bank-info">
          <button
            type="button"
            class="bank-info__row"
            data-copy-value="Fundación Brigada Galgos"
            aria-label="Nombre Fundación Brigada Galgos. Copiar dato."
          >
            <span class="bank-info__label">Nombre</span>
            <span class="bank-info__value">Fundación Brigada Galgos</span>
          </button>
          <button
            type="button"
            class="bank-info__row"
            data-copy-value="65.132.425-4"
            aria-label="RUT 65.132.425-4. Copiar dato."
          >
            <span class="bank-info__label">RUT</span>
            <span class="bank-info__value">65.132.425-4</span>
          </button>
          <button
            type="button"
            class="bank-info__row"
            data-copy-value="Mercado Pago"
            aria-label="Banco Mercado Pago. Copiar dato."
          >
            <span class="bank-info__label">Banco</span>
            <span class="bank-info__value">Mercado Pago</span>
          </button>
          <button
            type="button"
            class="bank-info__row"
            data-copy-value="Cuenta Vista"
            aria-label="Tipo de cuenta Cuenta Vista. Copiar dato."
          >
            <span class="bank-info__label">Tipo de cuenta</span>
            <span class="bank-info__value">Cuenta Vista</span>
          </button>
          <button
            type="button"
            class="bank-info__row"
            data-copy-value="1073480715"
            aria-label="Número de cuenta 1073480715. Copiar dato."
          >
            <span class="bank-info__label">Número de cuenta</span>
            <span class="bank-info__value">1073480715</span>
          </button>
          <button
            type="button"
            class="bank-info__row"
            data-copy-value={SITE.email}
            aria-label={`Correo ${SITE.email}. Copiar dato.`}
          >
            <span class="bank-info__label">Correo</span>
            <span class="bank-info__value">{SITE.email}</span>
          </button>
        </div>
        <button type="button" class="btn btn--secondary" id="copy-bank-data" aria-label="Copiar datos bancarios">
          Copiar datos
        </button>
        <div class="bank-info__live" data-copy-live aria-live="polite" aria-atomic="true"></div>
        <p class="donation-card__info">
          Si prefieres donar por transferencia, puedes copiar una fila individual o llevarte todos los datos de una vez.
        </p>
      </div>

      <div class="donation-card donation-card--mensual">
        <h3 class="donation-card__heading">AMIGOS DE LOS GALGOS</h3>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="currentColor"
          viewBox="0 0 588.22 125.01"
          class="donation-card__esponsor-logo"
          aria-label="eSponsor"
        >
          <g data-name="Capa 2">
            <path
              d="M120.817 125h-32a.6.6 0 0 1-.6-.9 2.1 2.1 0 0 0 .4-.6 15.8 15.8 0 0 0 2-10.6c-1.6-9.5-9.7-15.3-19.2-14s-15.8 10.9-13.5 20a40 40 0 0 0 2.2 5.3.6.6 0 0 1-.6.8h-26.9a6.1 6.1 0 0 1-6.1-6.1v-29a.6.6 0 0 0-.9-.5 16.6 16.6 0 0 1-11.2 2.4 16 16 0 0 1-10.7-6 16.5 16.5 0 0 1-.8-19.8 15.9 15.9 0 0 1 8.5-6.4 16.3 16.3 0 0 1 14.1 1.7.7.7 0 0 0 1-.6V32.4a6.1 6.1 0 0 1 6-6.1h26.9a.6.6 0 0 0 .5-.9 16.8 16.8 0 0 1 2.7-20.8 16.6 16.6 0 0 1 19.9-2.3 16.3 16.3 0 0 1 7.9 10.8 16.5 16.5 0 0 1-2.2 12.4.6.6 0 0 0 .6.9h26.8a6.1 6.1 0 0 1 6.1 6.1v28.4a.6.6 0 0 1-.9.6 16.6 16.6 0 0 0-22.7 23.2 16.4 16.4 0 0 0 8.1 6.6 16.6 16.6 0 0 0 14.7-1.4.6.6 0 0 1 .9.5v33.7a.9.9 0 0 1-1 .9m36.3-50.3c.3 4.2 1.5 7.5 3.7 10a11.3 11.3 0 0 0 8.8 3.8 12.5 12.5 0 0 0 6.4-1.7 7.3 7.3 0 0 0 3.5-4.6h15.2a24.1 24.1 0 0 1-9 13.3 25.7 25.7 0 0 1-15.4 4.6q-27.9 0-27.9-30.3a35.9 35.9 0 0 1 1.8-11.7 25.7 25.7 0 0 1 5.3-8.9 22.4 22.4 0 0 1 8.4-5.7 31.5 31.5 0 0 1 11.5-2c8.6 0 15.1 2.7 19.5 8.3s6.6 13.8 6.6 24.9zm23.2-9.3a14.4 14.4 0 0 0-1-5.4 11.6 11.6 0 0 0-2.6-3.8 8.6 8.6 0 0 0-3.6-2.3 12.3 12.3 0 0 0-4.2-.7 10.1 10.1 0 0 0-7.6 3.2c-2.2 2.1-3.4 5.1-3.7 9zm62.5-19.7c-.4-3.9-1.8-6.7-4.2-8.6s-6-2.9-10.7-2.9-7.8.8-10.1 2.3a7.3 7.3 0 0 0-3.4 6.6 6.8 6.8 0 0 0 2.7 5.7c1.7 1.5 4.7 2.7 9 3.8l12.2 3.1a70 70 0 0 1 10.1 3.4 35 35 0 0 1 4.6 2.7 12.7 12.7 0 0 1 3.7 3.6 15.2 15.2 0 0 1 2.5 5.1 23.1 23.1 0 0 1 .9 6.9 23.8 23.8 0 0 1-2.2 10.7 19.3 19.3 0 0 1-6.2 7.4 27.6 27.6 0 0 1-9.5 4.3 46 46 0 0 1-12.1 1.5 50 50 0 0 1-12.7-1.6 28 28 0 0 1-10-4.7 22.6 22.6 0 0 1-6.6-7.8 25.6 25.6 0 0 1-2.5-11.1h15.2a11.3 11.3 0 0 0 4.7 9.1c3 2.3 7 3.4 12.1 3.4s8.2-.9 10.8-2.8a9.2 9.2 0 0 0 3.8-7.9 7.3 7.3 0 0 0-.6-3 6.1 6.1 0 0 0-1.8-2.6 10.5 10.5 0 0 0-3.5-2.1 36.7 36.7 0 0 0-5.8-1.8l-11.8-2.7a50.4 50.4 0 0 1-8.8-3 23 23 0 0 1-9.3-7.1c-2.2-2.9-3.3-6.8-3.3-11.5a25.2 25.2 0 0 1 1.7-9.3 19.1 19.1 0 0 1 5.2-7.3 22.4 22.4 0 0 1 8.6-4.8 39 39 0 0 1 12-1.7 41 41 0 0 1 12.7 1.8 27.4 27.4 0 0 1 9.4 5.1 23.4 23.4 0 0 1 5.8 7.8 27.2 27.2 0 0 