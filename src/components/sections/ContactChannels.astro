---
import "../../styles/components/contact-channels.css";
import { SITE } from "../../config/site.ts";
import ExternalLink from "../../components/ExternalLink.astro";
import WhatsAppLink from "../../components/WhatsAppLink.astro";
---

<section class="section-padding">
  <div class="container">
    <p class="eyebrow">CANALES DIRECTOS</p>
    <h2 class="sr-only">Elige cómo quieres contactarnos</h2>
    <div class="contact-channels">
      <div class="channel-card">
        <span class="icon-circle icon-circle--green" aria-hidden="true">
          <img
            src="/icons/whatsapp.svg"
            alt=""
            aria-hidden="true"
            class="icon-circle__image"
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
          />
        </span>
        <h3 class="channel-card__title t-ui-title">WHATSAPP</h3>
        <p class="channel-card__detail">{SITE.whatsappPhone}</p>
        <p class="channel-card__hours t-small-muted">Lun a Vie · 10:00 – 19:00</p>
        <WhatsAppLink
          text="Hola, quiero hablar con Brigada Galgos"
          location="contact_channels"
          label="Abrir WhatsApp - Contact Channels"
          class="btn btn--primary"
        >
          Abrir WhatsApp <span class="sr-only"> (abre en una nueva pestaña)</span>
        </WhatsAppLink>
      </div>

      <div class="channel-card">
        <span class="icon-circle icon-circle--warm" aria-hidden="true">
          <img
            src="/icons/email.svg"
            alt=""
            aria-hidden="true"
            class="icon-circle__image"
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
          />
        </span>
        <h3 class="channel-card__title t-ui-title">EMAIL</h3>
        <p class="channel-card__detail">{SITE.email}</p>
        <p class="channel-card__hours t-small-muted">Respondemos lo antes posible.</p>
        <a href={`mailto:${SITE.email}`} class="btn btn--secondary"> Escribir por correo </a>
      </div>

      <div class="channel-card">
        <span class="icon-circle icon-circle--purple" aria-hidden="true">
          <img
            src="/icons/redes.svg"
            alt=""
            aria-hidden="true"
            class="icon-circle__image"
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
          />
        </span>
        <h3 class="channel-card__title t-ui-title">REDES</h3>
        <p class="channel-card__body t-card-body">Las novedades de los galgos viven en Instagram.</p>
        <div class="channel-card__social">
          <ExternalLink href={SITE.instagram} class="btn btn--ghost channel-card__social-link">
            <span class="btn__icon" aria-hidden="true">
              <img
                src="/icons/instagram.svg"
                alt=""
                aria-hidden="true"
                class="channel-card__social-icon"
                width="18"
                height="18"
                loading="lazy"
                decoding="async"
              />
            </span>
            <span>Instagram <span class="sr-only"> (abre en una nueva pestaña)</span></span>
          </ExternalLink>
          <ExternalLink href={SITE.facebook} class="btn btn--ghost channel-card__social-link">
            <span class="btn__icon" aria-hidden="true">
              <img
                src="/icons/facebook.svg"
                alt=""
                aria-hidden="true"
                class="channel-card__social-icon"
                width="18"
                height="18"
                loading="lazy"
                decoding="async"
              />
            </span>
            <span>Facebook <span class="sr-only"> (abre en una nueva pestaña)</span></span>
          </ExternalLink>
        </div>
      </div>
    </div>
  </div>
</section>
