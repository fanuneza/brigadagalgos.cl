---
import { SITE } from "../../config/site.ts";
import "../../styles/components/contact-channels.css";
---

<section class="section-padding">
  <div class="container">
    <p class="eyebrow">CANALES DIRECTOS</p>
    <div class="contact-channels">
      <div class="channel-card">
        <span class="icon-circle icon-circle--green" aria-hidden="true">
          <img
            src="/icons/whatsapp.svg"
            alt=""
            aria-hidden="true"
            class="icon-circle__image"
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
          />
        </span>
        <p class="channel-card__title">WHATSAPP</p>
        <p class="channel-card__detail">{SITE.whatsappPhone}</p>
        <p class="channel-card__hours">Lun a Vie · 10:00 – 19:00</p>
        <a href={SITE.whatsapp} class="btn btn--primary" target="_blank" rel="noopener noreferrer">
          Abrir WhatsApp <span class="sr-only"> (abre en una nueva pestaña)</span>
        </a>
      </div>

      <div class="channel-card">
        <span class="icon-circle icon-circle--warm" aria-hidden="true">
          <img
            src="/icons/email.svg"
            alt=""
            aria-hidden="true"
            class="icon-circle__image"
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
          />
        </span>
        <p class="channel-card__title">EMAIL</p>
        <p class="channel-card__detail">{SITE.email}</p>
        <p class="channel-card__hours">Respondemos lo antes posible.</p>
        <a href={`mailto:${SITE.email}`} class="btn btn--secondary"> Escribir por correo </a>
      </div>

      <div class="channel-card">
        <span class="icon-circle icon-circle--purple" aria-hidden="true">
          <img
            src="/icons/redes.svg"
            alt=""
            aria-hidden="true"
            class="icon-circle__image"
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
          />
        </span>
        <p class="channel-card__title">REDES</p>
        <p class="channel-card__body">Las novedades de los galgos viven en Instagram.</p>
        <div class="channel-card__social">
          <a
            href={SITE.instagram}
            class="btn btn--ghost channel-card__social-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="btn__icon" aria-hidden="true">
              <img
                src="/icons/instagram.svg"
                alt=""
                aria-hidden="true"
                class="channel-card__social-icon"
                width="18"
                height="18"
                loading="lazy"
                decoding="async"
              />
            </span>
            <span>Instagram <span class="sr-only"> (abre en una nueva pestaña)</span></span>
          </a>
          <a
            href={SITE.facebook}
            class="btn btn--ghost channel-card__social-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="btn__icon" aria-hidden="true">
              <img
                src="/icons/facebook.svg"
                alt=""
                aria-hidden="true"
                class="channel-card__social-icon"
                width="18"
                height="18"
                loading="lazy"
                decoding="async"
              />
            </span>
            <span>Facebook <span class="sr-only"> (abre en una nueva pestaña)</span></span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
