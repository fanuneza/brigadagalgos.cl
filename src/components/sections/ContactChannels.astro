---
import { SITE } from "../../config/site.ts";
import WhatsAppLink from "../../components/WhatsAppLink.astro";
import contactChannelsCss from "../../styles/components/contact-channels.css?raw";

const intentLinks = [
  {
    text: "Adopción",
    message: "Hola, quiero consultar por adopción de un galgo",
    category: "adoption",
  },
  {
    text: "Hogar temporal",
    message: "Hola, puedo ser hogar temporal y quisiera saber cómo empezar",
    category: "foster",
  },
  {
    text: "Donación",
    message: "Hola, quiero apoyar a un galgo y tengo una duda sobre donaciones",
    category: "donation",
  },
  {
    text: "Consulta general",
    message: "Hola, tengo una consulta para Brigada Galgos",
    category: "contact",
  },
];
---

<style is:inline set:html={contactChannelsCss}></style>

<section class="section-padding">
  <div class="container">
    <p class="eyebrow">CANALES DIRECTOS</p>
    <div class="contact-channels">
      <div class="channel-card">
        <span class="icon-circle icon-circle--green" aria-hidden="true">
          <img
            src="/icons/whatsapp.svg"
            alt=""
            aria-hidden="true"
            class="icon-circle__image"
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
          />
        </span>
        <p class="channel-card__title">WHATSAPP</p>
        <p class="channel-card__detail">{SITE.whatsappPhone}</p>
        <p class="channel-card__hours">Elige el motivo y te dejamos el mensaje listo para enviar.</p>
        <div class="channel-card__intents">
          {
            intentLinks.map((intent) => (
              <WhatsAppLink
                text={intent.message}
                location="contact_whatsapp_intents"
                label={`WhatsApp ${intent.text}`}
                class="btn btn--secondary channel-card__intent"
                data-track-category={intent.category}
              >
                {intent.text}
              </WhatsAppLink>
            ))
          }
        </div>
      </div>

      <div class="channel-card">
        <span class="icon-circle icon-circle--warm" aria-hidden="true">
          <img
            src="/icons/email.svg"
            alt=""
            aria-hidden="true"
            class="icon-circle__image"
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
          />
        </span>
        <p class="channel-card__title">EMAIL</p>
        <p class="channel-card__detail">{SITE.email}</p>
        <p class="channel-card__hours">También sirve si prefieres explicar tu caso con más detalle.</p>
        <a href={`mailto:${SITE.email}`} class="btn btn--secondary"> Escribir por correo </a>
      </div>

      <div class="channel-card">
        <span class="icon-circle icon-circle--purple" aria-hidden="true">
          <img
            src="/icons/redes.svg"
            alt=""
            aria-hidden="true"
            class="icon-circle__image"
            width="24"
            height="24"
            loading="lazy"
            decoding="async"
          />
        </span>
        <p class="channel-card__title">REDES</p>
        <p class="channel-card__body">Las novedades de los galgos viven en Instagram.</p>
        <div class="channel-card__social">
          <a
            href={SITE.instagram}
            class="btn btn--ghost channel-card__social-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="btn__icon" aria-hidden="true">
              <img
                src="/icons/instagram.svg"
                alt=""
                aria-hidden="true"
                class="channel-card__social-icon"
                width="18"
                height="18"
                loading="lazy"
                decoding="async"
              />
            </span>
            <span>Instagram</span>
          </a>
          <a
            href={SITE.facebook}
            class="btn btn--ghost channel-card__social-link"
            target="_blank"
            rel="noopener noreferrer"
          >
            <span class="btn__icon" aria-hidden="true">
              <img
                src="/icons/facebook.svg"
                alt=""
                aria-hidden="true"
                class="channel-card__social-icon"
                width="18"
                height="18"
                loading="lazy"
                decoding="async"
              />
            </span>
            <span>Facebook</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
