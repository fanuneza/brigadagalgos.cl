---
import "../../styles/components/adoption-grid.css";
import "../../styles/components/filter-chips.css";
import "../../styles/components/dog-card.css";
import type { AdoptionDogCard } from "../../utils/dog-content";
import SharedPhotoGallery from "../SharedPhotoGallery.astro";
import InstagramLink from "../InstagramLink.astro";
import WhatsAppLink from "../WhatsAppLink.astro";
import TrackedLink from "../TrackedLink.astro";
import { SITE } from "../../config/site.ts";
import { getInstagramHandleLabel } from "../../utils/instagram";

interface Props {
  dogs: AdoptionDogCard[];
}

const { dogs } = Astro.props;
---

<div class="filter-chips" role="group" aria-label="Filtrar galgos">
  <button class="chip-btn chip-btn--active" data-filter="all" aria-pressed="true">Todos</button>
  <button class="chip-btn" data-filter="Macho" aria-pressed="false">Macho</button>
  <button class="chip-btn" data-filter="Hembra" aria-pressed="false">Hembra</button>
  <button class="chip-btn" data-filter="adulto" aria-pressed="false">Adultos</button>
  <button class="chip-btn" data-filter="cachorro" aria-pressed="false">Cachorros</button>
</div>

<p class="dog-grid__count" aria-live="polite">
  <span data-count>{dogs.length}</span>
  <span data-count-label>{dogs.length === 1 ? "galgo disponible" : "galgos disponibles"}</span>
</p>

<div class="dog-grid" data-dog-grid>
  {
    dogs.map((dog, dogIndex) => {
      return (
        <article
          class="story-card dog-card adoption-card"
          data-adoption-card
          data-sex={dog.sex}
          data-age-type={dog.ageType}
        >
          <SharedPhotoGallery name={dog.name} photos={dog.pictures} loadingPriority={dogIndex < 2 ? "eager" : "lazy"} />

          <div class="story-card__body dog-card__body">
            <div class="dog-card__header">
              <h3 class="story-card__name dog-card__name t-card-title">
                <a
                  href={`/adoptar/${dog.id}/`}
                  class="dog-card__name-link"
                  data-track-event="dog_profile_click"
                  data-track-label={dog.name}
                  data-track-location="dog_card"
                  data-track-destination={`/adoptar/${dog.id}/`}
                >
                  {dog.name}
                </a>
              </h3>
              <div class="dog-card__chips">
                <span class="chip chip--sex">{dog.sex}</span>
                <span class="chip chip--age">{dog.age}</span>
                <span class="chip chip--weight">{dog.weight}</span>
                <span class="chip chip--need">{dog.currentNeed}</span>
              </div>
            </div>
            <p class="dog-card__details t-small-muted">{dog.details}</p>
            <p class="dog-card__sketch">{dog.characterSketch}</p>
            {dog.instagramUrl && (
              <InstagramLink url={dog.instagramUrl} name={dog.name} location="dog_card" class="dog-social-link">
                <img src="/icons/instagram.svg" alt="" aria-hidden="true" />
                <span>{getInstagramHandleLabel(dog.instagramUrl)}</span>
              </InstagramLink>
            )}
            <TrackedLink
              href={SITE.adoptionForm}
              class="btn btn--primary dog-card__cta"
              newTab
              trackEvent="adoption_apply_click"
              trackLabel={`Postular - ${dog.name}`}
              trackLocation="dog_card"
              trackDestination={SITE.adoptionForm}
              trackCategory="adoption"
              trackOutbound
            >
              Postular <span class="sr-only">por {dog.name} (abre en una nueva pestaña)</span>
            </TrackedLink>
            <WhatsAppLink
              text={`Hola, me interesa ${dog.name} y quisiera saber más sobre su adopción`}
              location="dog_card"
              label={`Más información - ${dog.name}`}
              class="btn btn--secondary dog-card__cta"
              data-dog-name={dog.name}
            >
              Más información <span class="sr-only">sobre {dog.name}</span>
            </WhatsAppLink>
            <a href={`/adoptar/${dog.id}/`} class="btn btn--ghost dog-card__profile-link">
              Ver ficha de {dog.name}
            </a>
          </div>
        </article>
      );
    })
  }
</div>

<p class="dog-grid__support-note">
  Seguimos acompañándote también después de la adopción, para que el proceso sea bueno para tu familia y para el galgo.
</p>

<div class="dog-grid__empty" hidden aria-hidden="true">
  <p>
    Por ahora no hay galgos publicados en adopción. Escríbenos igual y te avisamos cuando haya un galgo que pueda estar
    bien en tu hogar.
  </p>
  <WhatsAppLink
    text="Hola, quisiera adoptar un galgo"
    location="dog_grid_empty"
    label="Escríbenos por WhatsApp - Adoption Empty Grid"
    class="btn btn--primary"
  >
    Escríbenos por WhatsApp
  </WhatsAppLink>
</div>

<script>
  import "../../scripts/filter-chips";
  import "../../scripts/init-shared-gallery";
</script>
