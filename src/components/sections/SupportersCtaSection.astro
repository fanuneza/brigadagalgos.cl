---
import { SITE } from "../../config/site.ts";
import "../../styles/components/supporters-cta.css";
---

<section class="section-padding supporters-cta">
  <div class="container container--narrow">
    <p class="eyebrow">SUMAR APOYO</p>
    <h2>Si quieres colaborar, conversemos</h2>
    <p class="supporters-cta__lead">
      Si representas a una institución, marca o equipo profesional y quieres apoyar a Brigada Galgos, estaremos felices
      de explorar una forma de trabajo en conjunto.
    </p>
    <a
      href={`${SITE.whatsapp}?text=${encodeURIComponent("Hola, me interesa colaborar con Brigada Galgos")}`}
      class="btn btn--primary"
      target="_blank"
      rel="noopener noreferrer"
    >
      Hablar por WhatsApp <span class="sr-only"> (abre en una nueva pestaña)</span>
    </a>
  </div>
</section>
