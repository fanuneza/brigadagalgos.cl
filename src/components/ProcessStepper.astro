---
import stepperCss from "../styles/components/stepper.css?raw";

interface Step {
  label: string;
  subLabel: string;
  colorClass: string;
}

interface Props {
  steps: Step[];
  eyebrow?: string;
  heading?: string;
}

const { steps, eyebrow = "EL PROCESO", heading = "Asi rescatamos un galgo." } = Astro.props;
---

<style is:inline set:html={stepperCss}></style>

<section class="section-padding stepper-section" data-track-section="rescue_process">
  <div class="container">
    <p class="stepper__eyebrow">{eyebrow}</p>
    <h2 class="stepper__heading">{heading}</h2>
    <ol class="stepper" role="list">
      {
        steps.map((step, i) => (
          <li class="step">
            <div class={`step__badge step__badge--${step.colorClass}`} aria-hidden="true">
              {i + 1}
            </div>
            <div class="step__body">
              <p class="step__label">{step.label}</p>
              <p class="step__sub">{step.subLabel}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
