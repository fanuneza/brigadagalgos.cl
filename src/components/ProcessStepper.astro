---
interface Step {
  label: string;
  subLabel: string;
  colorClass: string;
}

interface Props {
  steps: Step[];
  eyebrow?: string;
  heading?: string;
}

const { steps, eyebrow = "EL PROCESO", heading = "Así rescatamos un galgo" } = Astro.props;
---

<section class="section-padding stepper-section" data-track-section="rescue_process">
  <div class="container">
    <p class="eyebrow">{eyebrow}</p>
    <h2 class="stepper__heading t-section-title">{heading}</h2>
    <ol class="stepper" role="list">
      {
        steps.map((step, i) => (
          <li class="step">
            <div class={`step__badge step__badge--${step.colorClass}`} aria-hidden="true">
              {i + 1}
            </div>
            <div class="step__body">
              <h3 class="step__label t-ui-title">{step.label}</h3>
              <p class="step__sub t-small-muted">{step.subLabel}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </div>
</section>
