---
const steps = [
  { num: 1, label: 'Recibimos el aviso',                  bg: 'var(--color-primary)',      fg: 'var(--color-text-inverse)' },
  { num: 2, label: 'Lo evaluamos y rescatamos',           bg: 'var(--color-secondary)',     fg: 'var(--color-text-inverse)' },
  { num: 3, label: 'Atención veterinaria completa',       bg: 'var(--color-accent-warm)',   fg: 'var(--color-text)' }, // charcoal — white on orange fails AA (1.7:1)
  { num: 4, label: 'Hogar temporal y rehabilitación',     bg: 'var(--color-rainbow-green)', fg: 'var(--color-text-inverse)' },
  { num: 5, label: 'Adopción definitiva',                 bg: 'var(--color-rainbow-purple)',fg: 'var(--color-text-inverse)' },
];
---

<section class="section-padding" style="background: var(--color-surface);">
  <div class="container">
    <p class="stepper__eyebrow">Así funciona</p>
    <h2 class="stepper__heading">El proceso de rescate</h2>
    <ol class="stepper" role="list">
      {steps.map((step) => (
        <li class="step">
          <div
            class="step__badge"
            style={`background: ${step.bg}; color: ${step.fg};`}
            aria-hidden="true"
          >
            {step.num}
          </div>
          <span class="step__label">{step.label}</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .stepper__eyebrow {
    font-family: var(--font-body);
    font-size: var(--font-size-xs);
    font-weight: var(--weight-semi);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eyebrow);
    color: var(--color-primary-700);
    margin: 0 0 var(--space-3);
  }

  .stepper__heading {
    font-size: var(--font-size-2xl);
    margin-bottom: var(--space-8);
  }

  .stepper {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .step {
    display: flex;
    align-items: flex-start;
    gap: var(--space-4);
    position: relative;
  }

  /* Vertical connector on mobile */
  .step:not(:last-child)::after {
    content: '';
    position: absolute;
    left: 23px;
    top: 48px;
    width: 2px;
    height: var(--space-5);
    background: var(--color-border);
  }

  .step__badge {
    width: 48px;
    height: 48px;
    flex-shrink: 0;
    border-radius: var(--radius-full);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: var(--weight-black);
  }

  .step__label {
    font-family: var(--font-display);
    font-size: var(--font-size-md);
    font-weight: var(--weight-semi);
    text-transform: uppercase;
    line-height: var(--line-tight);
    padding-top: 10px;
  }

  @media (min-width: 1024px) {
    .stepper {
      flex-direction: row;
      align-items: flex-start;
      justify-content: space-between;
    }

    .step {
      flex-direction: column;
      align-items: center;
      text-align: center;
      flex: 1;
    }

    .step__label {
      padding-top: var(--space-3);
    }

    /* Horizontal connector on desktop */
    .step:not(:last-child)::after {
      left: calc(50% + 28px);
      top: 23px;
      width: calc(100% - 56px);
      height: 2px;
    }
  }
</style>
