---
import { SITE } from "../config/site.ts";
import TrackedLink from "./TrackedLink.astro";
---

<section class="donation-banner" data-track-section="donation_banner">
  <div class="container donation-banner__grid">
    <div class="donation-banner__text">
      <h2>Tu aporte mantiene a los galgos seguros mientras esperan familia</h2>
      <p>
        Nos ayuda a cubrir comida, atención veterinaria, traslados e implementos para rescates y hogares temporales.
      </p>
    </div>
    <div class="donation-banner__cta">
      <TrackedLink
        href="/donar/"
        class="btn btn--primary"
        trackEvent="cta_click"
        trackLabel="Voy a apoyar un galgo"
        trackLocation="donation_banner"
        trackDestination="/donar/"
        trackCategory="donation"
      >
        Voy a apoyar un galgo
      </TrackedLink>
      <p class="donation-banner__transfer">
        También puedes donar en <TrackedLink
          href={SITE.esponsor}
          newTab
          hideExternalIndicator
          trackEvent="cta_click"
          trackLabel="eSponsor"
          trackLocation="donation_banner"
          trackDestination={SITE.esponsor}
          trackCategory="donation"
          trackOutbound
        >
          eSponsor<span class="sr-only"> (abre en una nueva pestaña)</span>
        </TrackedLink>
      </p>
    </div>
  </div>
</section>
