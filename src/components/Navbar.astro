---
import { SITE } from "../config/site.ts";
---

<header class="navbar" data-navbar>
  <div class="navbar__inner container">
    <a
      href="/"
      class="navbar__brand"
      aria-label="Brigada Galgos — inicio"
      data-track-event="navigation_click"
      data-track-label="logo"
      data-track-location="navbar"
      data-track-destination="/"
    >
      <img
        src="/images/brigada-galgos-logo.webp"
        alt=""
        class="navbar__mark"
        width="40"
        height="40"
        loading="eager"
        decoding="async"
        aria-hidden="true"
      />
      <span class="navbar__name">Brigada Galgos</span>
    </a>

    <nav class="navbar__nav" aria-label="Navegación principal">
      <a
        href="/"
        class="navbar__link"
        data-track-event="navigation_click"
        data-track-label="Inicio"
        data-track-location="desktop_nav"
        data-track-destination="/">Inicio</a
      >
      <a
        href="/adoptar/"
        class="navbar__link"
        data-track-event="navigation_click"
        data-track-label="Adoptar"
        data-track-location="desktop_nav"
        data-track-destination="/adoptar/">Adoptar</a
      >
      <a
        href="/hogar-temporal/"
        class="navbar__link"
        data-track-event="navigation_click"
        data-track-label="Hogar temporal"
        data-track-location="desktop_nav"
        data-track-destination="/hogar-temporal/">Hogar temporal</a
      >
      <a
        href="/por-que-galgos/"
        class="navbar__link"
        data-track-event="navigation_click"
        data-track-label="Por qué galgos"
        data-track-location="desktop_nav"
        data-track-destination="/por-que-galgos/">Por qué galgos</a
      >
      <a
        href="/colaboradores/"
        class="navbar__link"
        data-track-event="navigation_click"
        data-track-label="Colaboradores"
        data-track-location="desktop_nav"
        data-track-destination="/colaboradores/">Colaboradores</a
      >
      <a
        href="/contacto/"
        class="navbar__link"
        data-track-event="navigation_click"
        data-track-label="Contacto"
        data-track-location="desktop_nav"
        data-track-destination="/contacto/">Contacto</a
      >
    </nav>

    <a
      href="/donar/"
      class="btn btn--primary navbar__cta"
      data-track-event="cta_click"
      data-track-label="Quiero donar"
      data-track-location="navbar"
      data-track-destination="/donar/"
      data-track-category="donation"
    >
      Quiero donar
    </a>

    <button
      class="navbar__hamburger"
      data-hamburger
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="navbar-drawer"
    >
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>

  <div class="navbar__backdrop" data-backdrop aria-hidden="true"></div>

  <div class="navbar__drawer" id="navbar-drawer" data-drawer hidden inert>
    <button class="drawer__close" data-close aria-label="Cerrar menú">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></line>
        <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></line>
      </svg>
    </button>

    <nav aria-label="Menú móvil">
      <a
        href="/"
        class="drawer__link"
        data-track-event="navigation_click"
        data-track-label="Inicio"
        data-track-location="mobile_drawer"
        data-track-destination="/">Inicio</a
      >
      <a
        href="/adoptar/"
        class="drawer__link"
        data-track-event="navigation_click"
        data-track-label="Adoptar"
        data-track-location="mobile_drawer"
        data-track-destination="/adoptar/">Adoptar</a
      >
      <a
        href="/hogar-temporal/"
        class="drawer__link"
        data-track-event="navigation_click"
        data-track-label="Hogar temporal"
        data-track-location="mobile_drawer"
        data-track-destination="/hogar-temporal/">Hogar temporal</a
      >
      <a
        href="/por-que-galgos/"
        class="drawer__link"
        data-track-event="navigation_click"
        data-track-label="Por qué galgos"
        data-track-location="mobile_drawer"
        data-track-destination="/por-que-galgos/">Por qué galgos</a
      >
      <a
        href="/colaboradores/"
        class="drawer__link"
        data-track-event="navigation_click"
        data-track-label="Colaboradores"
        data-track-location="mobile_drawer"
        data-track-destination="/colaboradores/">Colaboradores</a
      >
      <a
        href="/contacto/"
        class="drawer__link"
        data-track-event="navigation_click"
        data-track-label="Contacto"
        data-track-location="mobile_drawer"
        data-track-destination="/contacto/">Contacto</a
      >
    </nav>

    <hr class="drawer__separator" />

    <a
      href="/donar/"
      class="btn btn--primary drawer__cta"
      data-track-event="cta_click"
      data-track-label="Quiero donar"
      data-track-location="mobile_drawer"
      data-track-destination="/donar/"
      data-track-category="donation"
    >
      Quiero donar
    </a>

    <div class="drawer__social">
      <a
        href={SITE.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp"
        data-external-indicator="off"
        data-track-event="social_click"
        data-track-label="WhatsApp"
        data-track-location="mobile_drawer"
        data-track-destination={SITE.whatsapp}
        data-track-category="whatsapp"
        data-track-outbound="true"
      >
        <img src="/icons/whatsapp.svg" alt="" aria-hidden="true" class="drawer__social-icon" width="24" height="24" loading="lazy" decoding="async" />
      </a>
      <a
        href={SITE.instagram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        data-external-indicator="off"
        data-track-event="social_click"
        data-track-label="Instagram"
        data-track-location="mobile_drawer"
        data-track-destination={SITE.instagram}
        data-track-category="instagram"
        data-track-outbound="true"
      >
        <img src="/icons/instagram.svg" alt="" aria-hidden="true" class="drawer__social-icon" width="24" height="24" loading="lazy" decoding="async" />
      </a>
      <a
        href={SITE.facebook}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Facebook"
        data-external-indicator="off"
        data-track-event="social_click"
        data-track-label="Facebook"
        data-track-location="mobile_drawer"
        data-track-destination={SITE.facebook}
        data-track-category="facebook"
        data-track-outbound="true"
      >
        <img src="/icons/facebook.svg" alt="" aria-hidden="true" class="drawer__social-icon" width="24" height="24" loading="lazy" decoding="async" />
      </a>
    </div>
  </div>
</header>

<script>
  import "../scripts/navbar";
</script>
