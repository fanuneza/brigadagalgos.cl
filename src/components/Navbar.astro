---
import { SITE } from "../config/site.ts";

const { pathname } = Astro.url;
const nav = [
  { href: "/", label: "Inicio" },
  { href: "/adoptar/", label: "Adoptar" },
  { href: "/hogar-temporal/", label: "Hogar temporal" },
  { href: "/por-que-galgos/", label: "Por qué galgos" },
  { href: "/colaboradores/", label: "Colaboradores" },
  { href: "/contacto/", label: "Contacto" },
];
---

<header class="navbar" data-navbar>
  <div class="navbar__inner container">
    <a
      href="/"
      class="navbar__brand"
      aria-label="Brigada Galgos — inicio"
      data-track-event="navigation_click"
      data-track-label="logo"
      data-track-location="navbar"
      data-track-destination="/"
    >
      <img
        src="/images/brigada-galgos-logo.webp"
        alt="Logo de Brigada Galgos de la barra de navegación"
        aria-hidden="true"
        class="navbar__mark"
        width="40"
        height="40"
        loading="eager"
        decoding="async"
      />
      <span class="navbar__name">Brigada Galgos</span>
    </a>

    <nav class="navbar__nav" aria-label="Navegación principal">
      {
        nav.map(({ href, label }) => (
          <a
            href={href}
            class="navbar__link"
            aria-current={pathname === href ? "page" : undefined}
            data-track-event="navigation_click"
            data-track-label={label}
            data-track-location="desktop_nav"
            data-track-destination={href}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <button
      type="button"
      class="theme-toggle navbar__theme-toggle"
      data-theme-toggle
      aria-label="Cambiar a modo oscuro"
      aria-pressed="false"
    >
      <svg
        class="theme-toggle__moon"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
      </svg>
      <svg
        class="theme-toggle__sun"
        width="16"
        height="16"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2.5"
        stroke-linecap="round"
        aria-hidden="true"
      >
        <circle cx="12" cy="12" r="4"></circle><line x1="12" y1="2" x2="12" y2="5"></line><line
          x1="12"
          y1="19"
          x2="12"
          y2="22"></line><line x1="2" y1="12" x2="5" y2="12"></line><line x1="19" y1="12" x2="22" y2="12"></line><line
          x1="5.64"
          y1="5.64"
          x2="7.76"
          y2="7.76"></line><line x1="16.24" y1="16.24" x2="18.36" y2="18.36"></line><line
          x1="5.64"
          y1="18.36"
          x2="7.76"
          y2="16.24"></line><line x1="16.24" y1="7.76" x2="18.36" y2="5.64"></line>
      </svg>
    </button>

    <a
      href="/donar/"
      class="btn btn--primary navbar__cta"
      data-track-event="cta_click"
      data-track-label="Quiero donar"
      data-track-location="navbar"
      data-track-destination="/donar/"
      data-track-category="donation"
    >
      Quiero donar
    </a>

    <button
      class="navbar__hamburger"
      data-hamburger
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="navbar-drawer"
    >
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>

  <div class="navbar__backdrop" data-backdrop aria-hidden="true"></div>

  <div class="navbar__drawer" id="navbar-drawer" data-drawer hidden inert>
    <button class="drawer__close" data-close aria-label="Cerrar menú">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></line>
        <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></line>
      </svg>
    </button>

    <nav aria-label="Menú móvil">
      {
        nav.map(({ href, label }) => (
          <a
            href={href}
            class="drawer__link"
            aria-current={pathname === href ? "page" : undefined}
            data-track-event="navigation_click"
            data-track-label={label}
            data-track-location="mobile_drawer"
            data-track-destination={href}
          >
            {label}
          </a>
        ))
      }
    </nav>

    <hr class="drawer__separator" />

    <a
      href="/donar/"
      class="btn btn--primary drawer__cta"
      data-track-event="cta_click"
      data-track-label="Quiero donar"
      data-track-location="mobile_drawer"
      data-track-destination="/donar/"
      data-track-category="donation"
    >
      Quiero donar
    </a>

    <div class="drawer__social">
      <a
        href={SITE.whatsapp}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="WhatsApp"
        data-external-indicator="off"
        data-track-event="social_click"
        data-track-label="WhatsApp"
        data-track-location="mobile_drawer"
        data-track-destination={SITE.whatsapp}
        data-track-category="whatsapp"
        data-track-outbound="true"
      >
        <img
          src="/icons/whatsapp.svg"
          alt=""
          aria-hidden="true"
          class="drawer__social-icon"
          width="24"
          height="24"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a
        href={SITE.instagram}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Instagram"
        data-external-indicator="off"
        data-track-event="social_click"
        data-track-label="Instagram"
        data-track-location="mobile_drawer"
        data-track-destination={SITE.instagram}
        data-track-category="instagram"
        data-track-outbound="true"
      >
        <img
          src="/icons/instagram.svg"
          alt=""
          aria-hidden="true"
          class="drawer__social-icon"
          width="24"
          height="24"
          loading="lazy"
          decoding="async"
        />
      </a>
      <a
        href={SITE.facebook}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Facebook"
        data-external-indicator="off"
        data-track-event="social_click"
        data-track-label="Facebook"
        data-track-location="mobile_drawer"
        data-track-destination={SITE.facebook}
        data-track-category="facebook"
        data-track-outbound="true"
      >
        <img
          src="/icons/facebook.svg"
          alt=""
          aria-hidden="true"
          class="drawer__social-icon"
          width="24"
          height="24"
          loading="lazy"
          decoding="async"
        />
      </a>
    </div>
  </div>
</header>

<script>
  import "../scripts/navbar";
</script>
