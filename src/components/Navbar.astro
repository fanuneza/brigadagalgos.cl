---
import { SITE } from "../config/site.ts";
---

<header class="navbar" data-navbar>
  <div class="navbar__inner container">
    <a href="/" class="navbar__brand" aria-label="Brigada Galgos — inicio">
      <img
        src="/images/brigada-galgos-mark.png"
        alt=""
        class="navbar__mark"
        width="40"
        height="40"
        loading="eager"
        aria-hidden="true"
      />
      <span class="navbar__name">Brigada Galgos</span>
    </a>

    <nav class="navbar__nav" aria-label="Navegación principal">
      <a href="/adoptar/" class="navbar__link" data-astro-prefetch>Adoptar</a>
      <a href="/hogar-temporal/" class="navbar__link" data-astro-prefetch>Hogar temporal</a>
      <a href="/colaboradores/" class="navbar__link" data-astro-prefetch>Colaboradores</a>
      <a href="/contacto/" class="navbar__link" data-astro-prefetch>Contacto</a>
    </nav>

    <a href="/donar/" class="btn btn--primary navbar__cta" data-astro-prefetch>Quiero donar</a>

    <button
      class="navbar__hamburger"
      data-hamburger
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="navbar-drawer"
    >
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
      <span class="hamburger__bar"></span>
    </button>
  </div>

  <div class="navbar__backdrop" data-backdrop aria-hidden="true"></div>

  <div class="navbar__drawer" id="navbar-drawer" data-drawer aria-hidden="true">
    <button class="drawer__close" data-close aria-label="Cerrar menú">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <line x1="18" y1="6" x2="6" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></line>
        <line x1="6" y1="6" x2="18" y2="18" stroke="currentColor" stroke-width="2" stroke-linecap="round"></line>
      </svg>
    </button>

    <nav aria-label="Menú móvil">
      <a href="/adoptar/" class="drawer__link" data-astro-prefetch>Adoptar</a>
      <a href="/hogar-temporal/" class="drawer__link" data-astro-prefetch>Hogar temporal</a>
      <a href="/colaboradores/" class="drawer__link" data-astro-prefetch>Colaboradores</a>
      <a href="/contacto/" class="drawer__link" data-astro-prefetch>Contacto</a>
    </nav>

    <hr class="drawer__separator" />

    <a href="/donar/" class="btn btn--primary drawer__cta" data-astro-prefetch>Quiero donar</a>

    <div class="drawer__social">
      <a href={SITE.whatsapp} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
        <img src="/icons/whatsapp.svg" alt="" aria-hidden="true" class="drawer__social-icon" width="24" height="24" />
      </a>
      <a href={SITE.instagram} target="_blank" rel="noopener noreferrer" aria-label="Instagram">
        <img src="/icons/instagram.svg" alt="" aria-hidden="true" class="drawer__social-icon" width="24" height="24" />
      </a>
      <a href={SITE.facebook} target="_blank" rel="noopener noreferrer" aria-label="Facebook">
        <img src="/icons/facebook.svg" alt="" aria-hidden="true" class="drawer__social-icon" width="24" height="24" />
      </a>
    </div>
  </div>
</header>

<script>
  import "../scripts/navbar";
</script>
