---
import TrackedLink from "./TrackedLink.astro";

interface Props {
  eyebrow: string;
  h1: string;
  lead?: string;
  leadBold?: string;
  ctaText?: string;
  ctaHref?: string;
  ctaVariant?: "primary" | "secondary" | "ghost";
  ctaTrackLabel?: string;
  ctaTrackLocation?: string;
  ctaTrackCategory?: string;
}

const {
  eyebrow,
  h1,
  lead,
  leadBold,
  ctaText,
  ctaHref,
  ctaVariant = "ghost",
  ctaTrackLabel,
  ctaTrackLocation,
  ctaTrackCategory,
} = Astro.props;
---

<section class="page-hero section-padding">
  <div class="container container--narrow">
    <p class="eyebrow">{eyebrow}</p>
    <h1>{h1}</h1>
    {lead && <p class="page-hero__lead t-lead">{lead}</p>}
    {leadBold && <p class="page-hero__lead page-hero__lead--bold t-lead t-lead-strong">{leadBold}</p>}
    {
      ctaText && ctaHref && (
        <TrackedLink
          href={ctaHref}
          class={`btn btn--${ctaVariant}`}
          trackEvent="cta_click"
          trackLabel={ctaTrackLabel ?? ctaText}
          trackLocation={ctaTrackLocation ?? ""}
          trackDestination={ctaHref}
          trackCategory={ctaTrackCategory}
        >
          {ctaText}
        </TrackedLink>
      )
    }
  </div>
</section>
