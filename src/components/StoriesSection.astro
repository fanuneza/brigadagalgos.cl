---
import "../styles/components/stories.css";
import type { StoryDogSummary } from "../utils/dog-content";
import StoryCard from "./StoryCard.astro";
import TrackedLink from "./TrackedLink.astro";

interface Props {
  dogs: StoryDogSummary[];
}

const { dogs } = Astro.props;
---

<section id="historias" class="section-padding stories" data-track-section="success_stories">
  <div class="container">
    <p class="eyebrow">Historias</p>
    <h2 class="stories__heading t-section-title">Historias con final de hogar</h2>
    <p class="stories__lead">
      Una parte del camino ya está escrita: estos galgos fueron adoptados y hoy viven acompañados. Sus historias
      muestran lo que puede abrir una adopción responsable.
    </p>

    <div class="stories__grid" data-stories-list>
      {dogs.map((dog) => <StoryCard story={dog} location="homepage_success_stories" summary />)}
    </div>
    <div class="stories__ver-mas-wrap">
      <TrackedLink
        href="/casos-de-exito/"
        class="btn btn--secondary"
        trackEvent="cta_click"
        trackLabel="Ver todas las historias - Homepage Success Stories"
        trackLocation="homepage_success_stories"
        trackDestination="/casos-de-exito/"
        trackCategory="success_stories"
      >
        Ver todas las historias
      </TrackedLink>
    </div>
  </div>
</section>
