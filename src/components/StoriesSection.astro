---
const stories = [
  {
    slug: 'rocko',
    name: 'Rocko',
    img: 'jannik.webp',
    quote: 'Llegó con miedo a todo. Hoy duerme en cama, acurrucado contra su familia adoptante.',
  },
  {
    slug: 'luna',
    name: 'Luna',
    img: 'hanlin.webp',
    quote: 'La encontramos muy débil, pesaba 12 kilos. Ocho meses después, su hogar temporal no se pudo resistir y la adoptó.',
  },
  {
    slug: 'toni',
    name: 'Toni',
    img: 'joe.webp',
    quote: 'Cuatro meses en rescate, tres cirugías. Su familia dice que no se imaginan la vida sin él.',
  },
];
---

<section class="section-padding stories">
  <div class="container">
    <p class="stories__eyebrow">Historias</p>
    <h2 class="stories__heading">Sus historias.</h2>

    <div class="stories__scroll">
      {stories.map((dog) => (
        <article class="story-card">
          <div class="story-card__photo">
            <img
              src={`/images/${dog.img}`}
              alt={`${dog.name}, galgo rescatado`}
              class="story-card__img"
              loading="lazy"
              decoding="async"
              width="400"
              height="400"
            />
          </div>
          <div class="story-card__body">
            <p class="story-card__name">{dog.name}</p>
            <p class="story-card__quote">"{dog.quote}"</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
