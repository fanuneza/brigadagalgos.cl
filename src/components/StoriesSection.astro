---
import SharedPhotoGallery from "./SharedPhotoGallery.astro";
import SharedGalleryLightbox from "./SharedGalleryLightbox.astro";
import type { SharedGalleryPhoto } from "../scripts/shared-gallery";
import storiesCss from "../styles/components/stories.css?raw";
import { getInstagramHandleLabel } from "../utils/instagram";

interface StoryDog {
  id: string;
  name: string;
  story: string;
  instagramUrl?: string;
  photos: SharedGalleryPhoto[];
}

interface Props {
  dogs: StoryDog[];
  totalCount: number;
  endpoint: string;
}

const { dogs, totalCount, endpoint } = Astro.props;
---

<style is:inline set:html={storiesCss}></style>

<section
  class="section-padding stories"
  data-stories-root
  data-stories-endpoint={endpoint}
  data-stories-loaded={String(dogs.length)}
  data-track-section="success_stories"
>
  <div class="container">
    <p class="stories__eyebrow">Historias</p>
    <h2 class="stories__heading">Nuestros casos de exito.</h2>

    <div class="stories__grid" data-stories-list>
      {
        dogs.map((dog) => (
          <article
            class="story-card"
            data-story-card
            data-story-id={dog.id}
            data-story-name={dog.name}
            data-story-location="success_stories"
          >
            <SharedPhotoGallery name={dog.name} photos={dog.photos} id={dog.id} />
            <div
              class="story-card__body"
              data-track-event="story_click"
              data-track-label={dog.name}
              data-track-location="success_stories"
              data-story-id={dog.id}
              data-story-name={dog.name}
            >
              <p class="story-card__name">{dog.name}</p>
              <p class="story-card__quote">{dog.story}</p>
              {dog.instagramUrl && (
                <a
                  href={dog.instagramUrl}
                  class="story-card__social dog-social-link"
                  aria-label={`Seguir a ${dog.name} en Instagram`}
                  target="_blank"
                  rel="noopener noreferrer"
                  data-external-indicator="off"
                  data-track-event="social_click"
                  data-track-category="instagram"
                  data-track-outbound="true"
                  data-social-platform="instagram"
                  data-dog-name={dog.name}
                  data-track-location="success_stories"
                  data-track-destination={dog.instagramUrl}
                >
                  <img src="/icons/instagram.svg" alt="" aria-hidden="true" />
                  <span>{getInstagramHandleLabel(dog.instagramUrl)}</span>
                </a>
              )}
            </div>
          </article>
        ))
      }
    </div>

    {
      totalCount > dogs.length && (
        <div class="stories__ver-mas-wrap">
          <button type="button" class="btn btn--secondary" data-stories-ver-mas>
            Ver mas historias
          </button>
        </div>
      )
    }
  </div>
</section>

<SharedGalleryLightbox ariaLabel="Galeria de historias" />

<script>
  import "../scripts/stories-section";
</script>
