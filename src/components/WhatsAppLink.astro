---
import { SITE } from "../config/site.ts";
import type { HTMLAttributes } from "astro/types";
import TrackedLink from "./TrackedLink.astro";

interface Props extends HTMLAttributes<"a"> {
  text: string;
  location: string;
  label?: string;
}

const { text, location, label, class: className, ...anchorProps } = Astro.props;
const href = `${SITE.whatsapp}?text=${encodeURIComponent(text)}`;
---

<TrackedLink
  {...anchorProps}
  href={href}
  class={className}
  newTab
  hideExternalIndicator
  trackEvent="whatsapp_click"
  trackLabel={label ?? "Escríbenos por WhatsApp"}
  trackLocation={location}
  trackDestination={href}
  trackCategory="whatsapp"
  trackOutbound
  data-whatsapp-location={location}
  data-whatsapp-text={text}
>
  <slot />
</TrackedLink>
