---
import { SITE } from "../config/site.ts";

interface Props {
  canonicalUrl: string;
  title: string;
  description: string;
}

const { canonicalUrl, title, description } = Astro.props;
const { siteUrl, email, whatsappPhone, instagram, facebook } = SITE;

const organization = {
  "@context": "https://schema.org",
  "@type": "NGO",
  "@id": `${siteUrl}/#organization`,
  name: "Fundación Brigada Galgos",
  alternateName: "Brigada Galgos",
  url: siteUrl,
  logo: `${siteUrl}/images/brigada-galgos-logo.webp`,
  image: `${siteUrl}/images/brigada-galgos-og-image.webp`,
  description: "Fundación chilena que rescata, rehabilita y reubica galgos abandonados.",
  email,
  telephone: whatsappPhone,
  taxID: "65.132.425-4",
  areaServed: { "@type": "Country", name: "Chile" },
  sameAs: [instagram, facebook],
  contactPoint: [
    {
      "@type": "ContactPoint",
      contactType: "customer service",
      telephone: whatsappPhone,
      email,
      availableLanguage: ["Spanish"],
      areaServed: "CL",
    },
  ],
};

const website = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  url: siteUrl,
  name: "Brigada Galgos",
  description: "Fundación chilena que rescata, rehabilita y reubica galgos abandonados.",
  inLanguage: "es-CL",
  publisher: { "@id": `${siteUrl}/#organization` },
};

const webpage = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  url: canonicalUrl,
  name: title,
  description,
  inLanguage: "es-CL",
  isPartOf: { "@id": `${siteUrl}/#website` },
};

const pathSegments = Astro.url.pathname.split("/").filter(Boolean);
const breadcrumbLabels: Record<string, string> = {
  adoptar: "Adoptar",
  "hogar-temporal": "Hogar temporal",
  "por-que-galgos": "Por qué galgos",
  colaboradores: "Colaboradores",
  donar: "Donar",
  contacto: "Contacto",
  "politica-de-cookies": "Política de cookies",
};

const breadcrumb = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Inicio", item: `${siteUrl}/` },
    ...pathSegments.map((seg, i) => ({
      "@type": "ListItem",
      position: i + 2,
      name: breadcrumbLabels[seg] ?? seg,
      item: `${siteUrl}/${pathSegments.slice(0, i + 1).join("/")}/`,
    })),
  ],
};

const graph: Record<string, unknown>[] = [organization, website, webpage];
if (pathSegments.length > 0) graph.push(breadcrumb);

if (Astro.url.pathname === "/por-que-galgos/") {
  graph.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: [
      {
        "@type": "Question",
        name: "¿Los galgos son tranquilos en casa?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Sí. Son perros tranquilos en casa y se adaptan bien a departamentos. Con dos caminatas al día están felices.",
        },
      },
      {
        "@type": "Question",
        name: "¿Se llevan bien con niños y otros animales?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "La mayoría se lleva bien con niños y otros animales cuando se hace una presentación adecuada.",
        },
      },
      {
        "@type": "Question",
        name: "¿Cuánto ejercicio necesita un galgo?",
        acceptedAnswer: {
          "@type": "Answer",
          text: "Dos caminatas al día son suficientes. Son atletas de carrera corta: explosivos en pista, pero serenos en casa.",
        },
      },
    ],
  });
}

const ld = { "@context": "https://schema.org", "@graph": graph };
---

<script type="application/ld+json" set:html={JSON.stringify(ld)} is:inline />
