---
import { buildStructuredDataGraph, type StructuredDataInput } from "../utils/structured-data";

type Props = Omit<StructuredDataInput, "pathname">;

const { canonicalUrl, title, description, imageUrl, logoUrl } = Astro.props;
const ld = buildStructuredDataGraph({
  canonicalUrl,
  title,
  description,
  imageUrl,
  logoUrl,
  pathname: Astro.url.pathname,
});
---

<script type="application/ld+json" set:html={JSON.stringify(ld)} is:inline />
