---
import { getInstagramHandleLabel } from "../utils/instagram";
import type { HTMLAttributes } from "astro/types";
import TrackedLink from "./TrackedLink.astro";

interface Props extends HTMLAttributes<"a"> {
  url: string;
  name: string;
  location?: string;
}

const { url, name, location = "success_stories", class: className, ...anchorProps } = Astro.props;
const handle = getInstagramHandleLabel(url);
---

<TrackedLink
  {...anchorProps}
  href={url}
  class={className}
  aria-label={`Seguir a ${name} en Instagram: ${handle}`}
  newTab
  hideExternalIndicator
  trackEvent="social_click"
  trackLabel="Instagram"
  trackCategory="instagram"
  trackOutbound
  data-social-platform="instagram"
  data-dog-name={name}
  trackLocation={location}
  trackDestination={url}
>
  <slot />
</TrackedLink>
