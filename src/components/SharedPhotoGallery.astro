---
import { buildSharedGalleryMarkup, type SharedGalleryPhoto } from "../scripts/shared-gallery";

interface Props {
  id?: string;
  name: string;
  photos: SharedGalleryPhoto[];
}

const { id, name, photos } = Astro.props;
---

<Fragment set:html={buildSharedGalleryMarkup({ id, name, photos })} />
