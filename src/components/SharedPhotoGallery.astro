---
import "../styles/components/shared-gallery.css";
import { buildSharedGalleryMarkup, type SharedGalleryPhoto } from "../scripts/gallery";

interface Props {
  id?: string;
  name: string;
  photos: SharedGalleryPhoto[];
  loadingPriority?: "lazy" | "eager";
}

const { id, name, photos, loadingPriority = "lazy" } = Astro.props;
---

<Fragment set:html={buildSharedGalleryMarkup({ id, name, photos }, loadingPriority)} />
