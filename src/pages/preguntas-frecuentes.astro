---
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import RainbowDivider from "../components/RainbowDivider.astro";
import FaqSection from "../components/sections/FaqSection.astro";
import NextStepCta from "../components/sections/NextStepCta.astro";
---

<PageLayout
  title="Preguntas frecuentes sobre adopción de galgos"
  description="Resolvemos tus dudas sobre adopción de galgos, hogar temporal, donaciones y convivencia. Rescatamos, rehabilitamos y reubicamos galgos en Chile."
>
  <PageHero
    eyebrow="RESPUESTAS DIRECTAS"
    h1="Preguntas frecuentes"
    lead="Sabemos que adoptar, ser hogar temporal o donar genera dudas. Aquí respondemos las que más nos hacen llegar, con la misma honestidad con la que trabajamos cada día."
  />
  <RainbowDivider />

  <FaqSection />
  <NextStepCta />
</PageLayout>
