---
import "../styles/components/page-hero.css";
import "../styles/components/stories.css";
import "../styles/components/dog-card.css";
import { getCollection } from "astro:content";
import type { SharedGalleryPhoto } from "../scripts/shared-gallery";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import SharedGalleryLightbox from "../components/SharedGalleryLightbox.astro";
import AdoptionIntro from "../components/sections/AdoptionIntro.astro";
import AdoptionGrid from "../components/sections/AdoptionGrid.astro";
import AdoptionProcess from "../components/sections/AdoptionProcess.astro";
import AdoptionTailCta from "../components/sections/AdoptionTailCta.astro";
import { createResponsiveGalleryPhoto } from "../utils/responsive-gallery-images";
import { shuffle } from "../utils/shuffle";

const rawDogs = await getCollection("adoption-dogs");

const dogs = await Promise.all(
  shuffle(rawDogs).map(async (entry) => ({
    id: entry.id,
    name: entry.data.name,
    sex: entry.data.sex,
    age: entry.data.age,
    weight: entry.data.weight,
    details: entry.data.details,
    instagramUrl: entry.data.instagramUrl,
    pictures: await Promise.all(
      entry.data.gallery.map(async (img): Promise<SharedGalleryPhoto> => createResponsiveGalleryPhoto(img))
    ),
  }))
);
---

<BaseLayout
  title="Adoptar | Brigada Galgos"
  description="Conoce a los galgos que hoy están listos para encontrar familia en Chile."
>
  <Navbar />
  <main id="main-content">
    <PageHero
      eyebrow="ADOPTA"
      h1="Los galgos que hoy esperan familia"
      lead="Los conocemos de cerca y te acompañamos en todo el proceso, desde tu primer mensaje hasta los primeros días en casa."
    />

    <section class="section-padding">
      <div class="container">
        <AdoptionIntro />
        <AdoptionGrid dogs={dogs} />
      </div>
    </section>

    <AdoptionProcess />
    <AdoptionTailCta />
  </main>
  <Footer />
</BaseLayout>

<SharedGalleryLightbox ariaLabel="Galería de adopción" />
