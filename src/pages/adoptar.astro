---
import { getCollection, type CollectionEntry } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import RainbowDivider from "../components/RainbowDivider.astro";
import SharedGalleryLightbox from "../components/SharedGalleryLightbox.astro";
import AdoptionIntro from "../components/sections/AdoptionIntro.astro";
import AdoptionGrid from "../components/sections/AdoptionGrid.astro";
import AdoptionProcess from "../components/sections/AdoptionProcess.astro";
import AdoptionTailCta from "../components/sections/AdoptionTailCta.astro";
import { SITE } from "../config/site.ts";
import { buildAdoptionDogCards } from "../utils/dog-content";
import { shuffle } from "../utils/shuffle";

const rawDogsList: CollectionEntry<"adoption-dogs">[] = await getCollection("adoption-dogs");
const rawDogs = rawDogsList.filter((dog) => dog.data.active !== false);
const dogs = await buildAdoptionDogCards(shuffle(rawDogs));
---

<PageLayout
  title="Adopta un galgo rescatado en Chile"
  description="Conoce a los galgos que hoy están listos para encontrar familia en Chile y te acompañamos durante todo el proceso de adopción."
>
  <PageHero
    eyebrow="ADOPTA"
    h1="Los galgos que hoy esperan familia"
    lead="Los conocemos de cerca y te acompañamos en todo el proceso, desde tu primer mensaje hasta los primeros días en casa."
    ctaText="Quiero adoptar"
    ctaHref={SITE.adoptionForm}
    ctaVariant="primary"
    ctaTrackLocation="adoption_hero"
    ctaTrackCategory="adoption"
  />
  <RainbowDivider />

  <section id="galgos" class="section-padding">
    <div class="container">
      <AdoptionIntro />
      <AdoptionGrid dogs={dogs} />
    </div>
  </section>

  <AdoptionProcess />
  <AdoptionTailCta />

  <SharedGalleryLightbox slot="afterShell" ariaLabel="Galería de adopción" />
</PageLayout>
