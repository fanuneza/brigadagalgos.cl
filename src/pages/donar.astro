---
import "../styles/components/page-hero.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import RainbowDivider from "../components/RainbowDivider.astro";
import DonationCards from "../components/sections/DonationCards.astro";
import ImpactSection from "../components/sections/ImpactSection.astro";
import TrustStatsSection from "../components/sections/TrustStatsSection.astro";
import HelpTailCta from "../components/sections/HelpTailCta.astro";
---

<BaseLayout
  title="Donar"
  description="Apoya el rescate de galgos en Chile. Dona a través de eSponsor o revisa otras formas de aporte."
>
  <Navbar />
  <main id="main-content">
    <PageHero
      eyebrow="DONAR"
      h1="Tu aporte acompaña a un galgo mientras espera familia"
      lead="Las donaciones mantienen a los galgos rescatados seguros, alimentados, tratados y acompañados durante su recuperación."
      leadBold="Puedes donar una vez, hacer un aporte mensual en eSponsor o transferir directo a Brigada Galgos."
      ctaText="Voy a apoyar un galgo"
      ctaHref="#datos-transferencia"
      ctaVariant="primary"
      ctaTrackLocation="donation_hero"
      ctaTrackCategory="donation"
    />
    <RainbowDivider />

    <DonationCards />
    <ImpactSection />
    <TrustStatsSection />
    <HelpTailCta />
  </main>
  <Footer />
</BaseLayout>
