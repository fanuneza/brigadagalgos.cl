---
import "../styles/components/home.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Hero from "../components/Hero.astro";
import RainbowDivider from "../components/RainbowDivider.astro";
import MissionSection from "../components/MissionSection.astro";
import HelpCards from "../components/HelpCards.astro";
import ProcessStepper from "../components/ProcessStepper.astro";
import StoriesSection from "../components/StoriesSection.astro";
import DonationBanner from "../components/DonationBanner.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";
import type { SharedGalleryPhoto } from "../scripts/shared-gallery";
import { createResponsiveGalleryPhoto } from "../utils/responsive-gallery-images";
import { shuffle } from "../utils/shuffle";

const rescueSteps = [
  {
    label: "Recibimos el aviso",
    subLabel: "Los casos suelen llegar por WhatsApp o redes sociales.",
    colorClass: "primary",
  },
  {
    label: "Rescate y traslado",
    subLabel: "Evaluamos la urgencia y movemos al galgo a un lugar seguro.",
    colorClass: "secondary",
  },
  {
    label: "Atención veterinaria integral",
    subLabel: "No solo lo básico: hacemos la evaluación y tratamiento que cada caso necesita.",
    colorClass: "warm",
  },
  {
    label: "Acogida temporal",
    subLabel: "Una familia lo recibe mientras se estabiliza y conocemos mejor su ritmo.",
    colorClass: "green",
  },
  {
    label: "Match y adopción responsable",
    subLabel: "Buscamos la familia correcta y acompañamos también después.",
    colorClass: "purple",
  },
];

const rawStoryDogs = shuffle(await getCollection("success-dogs")).filter((entry) => entry.data.gallery.length > 0);
const initialStoryDogs = rawStoryDogs.slice(0, 6);

const storyDogs = await Promise.all(
  initialStoryDogs.map(async (entry) => ({
    id: entry.id,
    name: entry.data.name,
    story: entry.data.story,
    instagramUrl: entry.data.instagramUrl,
    photos: await Promise.all(
      entry.data.gallery.map(async (img): Promise<SharedGalleryPhoto> => createResponsiveGalleryPhoto(img))
    ),
  }))
);
---

<BaseLayout
  title="Brigada Galgos | Rescatamos galgos en todo Chile"
  description="Fundación chilena que rescata, rehabilita y reubica galgos abandonados."
>
  <Navbar />
  <main id="main-content">
    <Hero />
    <RainbowDivider />
    <StoriesSection dogs={storyDogs} totalCount={rawStoryDogs.length} endpoint="/casos/exito-home.json" />
    <MissionSection />
    <section class="section-padding" data-track-section="why_galgos">
      <div class="container container--narrow">
        <p class="eyebrow">POR QUÉ UN GALGO</p>
        <h2 class="section-heading">Razones que te van a conquistar</h2>
        <ul class="requisitos-list">
          <li>Son tranquilos en casa y se adaptan bien a departamentos.</li>
          <li>Con dos caminatas al día están felices.</li>
          <li>Agradecen profundamente y se convierten en el corazón silencioso de la familia.</li>
          <li>La mayoría se lleva bien con niños y otros animales con una presentación adecuada.</li>
          <li>Rompen muchos mitos: pueden ser compañeros serenos, sensibles y muy nobles.</li>
        </ul>
        <p class="section-body">
          También los elegimos porque vemos de cerca el abandono, el abuso y la explotación que viven demasiados galgos
          en Chile.
        </p>
        <a
          href="/por-que-galgos/"
          class="btn btn--secondary home-why-galgo__cta"
          data-track-event="cta_click"
          data-track-label="Leer por qué galgos"
          data-track-location="why_galgos"
          data-track-destination="/por-que-galgos/"
          data-track-category="education"
        >
          Leer por qué galgos
        </a>
      </div>
    </section>
    <HelpCards />
    <ProcessStepper steps={rescueSteps} />
    <DonationBanner />
  </main>
  <Footer />
</BaseLayout>
