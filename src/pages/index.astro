---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import RainbowDivider from '../components/RainbowDivider.astro';
import MissionSection from '../components/MissionSection.astro';
import HelpCards from '../components/HelpCards.astro';
import ProcessStepper from '../components/ProcessStepper.astro';
import StoriesSection from '../components/StoriesSection.astro';
import DonationBanner from '../components/DonationBanner.astro';
import Footer from '../components/Footer.astro';

const rescueSteps = [
  { label: 'Recibimos el aviso', subLabel: 'Alguien ve al galgo y nos contacta por WhatsApp o redes.', color: 'var(--color-primary)' },
  { label: 'Evaluamos y rescatamos', subLabel: 'Vamos al lugar, evaluamos la situación y lo trasladamos.', color: 'var(--color-secondary)' },
  { label: 'Atención veterinaria', subLabel: 'Revisión completa, vacunas, desparasitación y todo lo que necesita.', color: 'var(--color-accent-warm)' },
  { label: 'Hogar temporal', subLabel: 'Una familia lo recibe y lo cuida mientras buscamos adopción.', color: 'var(--color-rainbow-green)' },
  { label: 'Adopción definitiva', subLabel: 'Encontramos la familia ideal y hacemos seguimiento.', color: 'var(--color-rainbow-purple)' },
];
---

<BaseLayout
  title="Brigada Galgos | Rescatamos galgos en todo Chile"
  description="Fundación chilena que rescata, rehabilita y reubica galgos abandonados."
>
  <Navbar />
  <main>
    <Hero />
    <RainbowDivider />
    <MissionSection />
    <section class="section-padding">
      <div class="container container--narrow">
        <p class="eyebrow">POR QUÉ UN GALGO</p>
        <h2>¿Te encaja un galgo?</h2>
        <ul class="requisitos-list">
          <li>Son tranquilos en casa y se adaptan bien a departamentos.</li>
          <li>Con dos caminatas cortas al día están felices.</li>
          <li>Agradecen profundamente y se convierten en el corazón silencioso de la familia.</li>
          <li>La mayoría se lleva bien con niños y otros animales con una presentación adecuada.</li>
          <li>No ladran mucho y disfrutan descansar tanto como salir a caminar.</li>
        </ul>
      </div>
    </section>
    <HelpCards />
    <ProcessStepper steps={rescueSteps} />
    <StoriesSection />
    <DonationBanner />
  </main>
  <Footer />
</BaseLayout>
