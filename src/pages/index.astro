---
import heroSrc from "../assets/images/hero.webp";
import Hero from "../components/Hero.astro";
import RainbowDivider from "../components/RainbowDivider.astro";
import MissionSection from "../components/MissionSection.astro";
import HelpCards from "../components/HelpCards.astro";
import ProcessStepper from "../components/ProcessStepper.astro";
import StoriesSection from "../components/StoriesSection.astro";
import DonationBanner from "../components/DonationBanner.astro";
import WhyGalgosSection from "../components/sections/WhyGalgosSection.astro";
import TrustStatsSection from "../components/sections/TrustStatsSection.astro";
import FeaturedAdoptionDogs from "../components/sections/FeaturedAdoptionDogs.astro";
import SharedGalleryLightbox from "../components/SharedGalleryLightbox.astro";
import PageLayout from "../layouts/PageLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import { buildAdoptionDogCards, buildStoryDogSummaries, getEntriesWithGallery } from "../utils/dog-content";
import { buildHeroImageSources } from "../utils/hero-images";
import { shuffle } from "../utils/shuffle";
import { buildWebSiteStructuredData } from "../utils/structured-data";

const webSiteSchema = buildWebSiteStructuredData();

const rescueSteps = [
  {
    label: "Recibimos el aviso",
    subLabel: "Los casos suelen llegar por WhatsApp o redes sociales.",
    colorClass: "primary",
  },
  {
    label: "Rescate y traslado",
    subLabel: "Evaluamos la urgencia y movemos al galgo a un lugar seguro.",
    colorClass: "secondary",
  },
  {
    label: "Atención veterinaria integral",
    subLabel: "No solo lo básico: hacemos la evaluación y tratamiento que cada caso necesita.",
    colorClass: "warm",
  },
  {
    label: "Acogida temporal",
    subLabel: "Una familia lo recibe mientras se estabiliza y conocemos mejor su ritmo.",
    colorClass: "green",
  },
  {
    label: "Familia y acompañamiento",
    subLabel: "Buscamos una familia segura y seguimos presentes después de la adopción.",
    colorClass: "purple",
  },
];

const adoptionDogs: CollectionEntry<"adoption-dogs">[] = await getCollection("adoption-dogs");
const successDogs: CollectionEntry<"success-dogs">[] = await getCollection("success-dogs");
const activeAdoptionDogs = adoptionDogs.filter((dog) => dog.data.active !== false);
const featuredDogs = await buildAdoptionDogCards(shuffle(activeAdoptionDogs).slice(0, 3));
const storyDogs = await buildStoryDogSummaries(
  getEntriesWithGallery(successDogs).sort((a, b) => a.data.name.localeCompare(b.data.name, "es")),
  3
);
const heroSources = await buildHeroImageSources(heroSrc);
---

<PageLayout
  title="Rescatamos galgos en todo Chile"
  description="Rescatamos, rehabilitamos y reubicamos galgos en Chile hasta encontrarles una familia segura."
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <link
      rel="preload"
      as="image"
      type="image/avif"
      imagesrcset={heroSources.portraitAvifSrcSet}
      imagesizes="calc((100vw - 48px) / 1.75)"
      media="(max-width: 767px)"
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="image"
      type="image/avif"
      imagesrcset={heroSources.landscapeAvifSrcSet}
      imagesizes="(min-width: 1200px) 528px, (min-width: 1024px) calc(50vw - 72px), calc(100vw - 48px)"
      media="(min-width: 768px)"
      fetchpriority="high"
    />
  </Fragment>
  <Hero sources={heroSources} activeDogsCount={activeAdoptionDogs.length} />
  <RainbowDivider />
  <FeaturedAdoptionDogs dogs={featuredDogs} />
  <MissionSection />
  <TrustStatsSection />
  <WhyGalgosSection />
  <StoriesSection dogs={storyDogs} />
  <ProcessStepper steps={rescueSteps} />
  <HelpCards />
  <DonationBanner />
  <SharedGalleryLightbox slot="afterShell" ariaLabel="Galería de Brigada Galgos" />
</PageLayout>
