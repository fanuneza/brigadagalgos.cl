---
import "../styles/components/page-hero.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import NotFoundLinks from "../components/sections/NotFoundLinks.astro";
---

<BaseLayout
  title="Página no encontrada | Brigada Galgos"
  description="No encontramos la página que buscas. Vuelve al inicio o explora los galgos disponibles para adopción."
>
  <Navbar />
  <main id="main-content">
    <PageHero
      eyebrow="ERROR 404"
      h1="No encontramos esta página"
      lead="Puede que el enlace esté roto o que el contenido se haya movido. Te dejamos algunas rutas para seguir."
    />
    <NotFoundLinks />
  </main>
  <Footer />
</BaseLayout>
