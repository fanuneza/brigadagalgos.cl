---
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import RainbowDivider from "../components/RainbowDivider.astro";
import NotFoundLinks from "../components/sections/NotFoundLinks.astro";
import FuzzyRedirect from "@jdevalk/astro-seo-graph/FuzzyRedirect.astro";
---

<PageLayout
  title="Página no encontrada"
  description="No encontramos la página que buscas. Vuelve al inicio o explora los galgos disponibles para adopción."
>
  <PageHero
    eyebrow="ERROR 404"
    h1="No encontramos esta página"
    lead="Puede que el enlace esté roto o que el contenido se haya movido. Te dejamos algunas rutas para seguir."
  />
  <div class="not-found-redirect">
    <FuzzyRedirect />
  </div>
  <RainbowDivider />
  <NotFoundLinks />
</PageLayout>
