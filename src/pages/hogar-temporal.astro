---
import "../styles/components/page-hero.css";
import "../styles/components/stepper.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import RainbowDivider from "../components/RainbowDivider.astro";
import ProcessStepper from "../components/ProcessStepper.astro";
import FosterRequirements from "../components/sections/FosterRequirements.astro";
import FosterPostular from "../components/sections/FosterPostular.astro";

const fosterSteps = [
  {
    label: "Nos escribes",
    subLabel: "Nos mandas un mensaje o completas el formulario con tu disponibilidad y dudas.",
    colorClass: "primary",
  },
  {
    label: "Conversamos y revisamos",
    subLabel: "Miramos seguridad, rutina, tiempos y convivencia para preparar una acogida responsable.",
    colorClass: "secondary",
  },
  {
    label: "Elegimos juntos el caso",
    subLabel: "Buscamos un galgo que pueda estar bien en tu casa y en la etapa que está viviendo.",
    colorClass: "warm",
  },
  {
    label: "Acompañamos el proceso",
    subLabel: "Te apoyamos durante el hogar temporal y coordinamos la transición cuando aparece su familia.",
    colorClass: "green",
  },
];
---

<BaseLayout
  title="Hogar temporal | Brigada Galgos"
  description="Sé hogar temporal de un galgo rescatado. Evaluamos contigo tiempos, seguridad e implementos para una acogida responsable."
>
  <Navbar />
  <main id="main-content">
    <PageHero
      eyebrow="HOGAR TEMPORAL"
      h1="Abre tu casa por un tiempo"
      lead="Ser hogar temporal es abrir tu casa por un tiempo para que un galgo esté seguro, acompañado y mejor preparado para encontrar familia."
      leadBold="No necesitas tener todo resuelto antes de escribirnos. Conversamos contigo qué puedes aportar y qué apoyo necesita cada caso."
      ctaText="Puedo ser hogar temporal"
      ctaHref="#form"
      ctaVariant="primary"
      ctaTrackLocation="foster_hero"
      ctaTrackCategory="foster"
    />
    <RainbowDivider />

    <FosterRequirements />
    <ProcessStepper steps={fosterSteps} eyebrow="EL PROCESO" heading="Así funciona el acogimiento" />
    <FosterPostular />
    <Footer />
  </main>
</BaseLayout>
