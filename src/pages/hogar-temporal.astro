---
import "../styles/components/page-hero.css";
import "../styles/components/stepper.css";
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import PageHero from "../components/PageHero.astro";
import RainbowDivider from "../components/RainbowDivider.astro";
import ProcessStepper from "../components/ProcessStepper.astro";
import FosterRequirements from "../components/sections/FosterRequirements.astro";
import FosterPostular from "../components/sections/FosterPostular.astro";

const fosterSteps = [
  {
    label: "Postulas desde la web",
    subLabel: "Nos cuentas tu disponibilidad, tu casa y quiénes viven contigo.",
    colorClass: "primary",
  },
  {
    label: "Te contacta el equipo",
    subLabel: "Conversamos sobre tiempos, implementos y tipo de convivencia.",
    colorClass: "secondary",
  },
  {
    label: "Entrevista y revisión",
    subLabel: "Revisamos requisitos de seguridad y el contexto del hogar.",
    colorClass: "warm",
  },
  {
    label: "Llega el galgo",
    subLabel: "Coordinamos la acogida y te acompañamos durante el proceso.",
    colorClass: "green",
  },
];
---

<BaseLayout
  title="Hogar temporal | Brigada Galgos"
  description="Sé hogar temporal de un galgo rescatado. Evaluamos contigo tiempos, seguridad e implementos para una acogida responsable."
>
  <Navbar />
  <main id="main-content">
    <PageHero
      eyebrow="HOGAR TEMPORAL"
      h1="¿No puedes adoptar todavía?"
      lead="Abrir tu casa por un tiempo le da al galgo un lugar seguro mientras se recupera y esperamos la familia correcta."
      leadBold="Evaluamos contigo tiempos, seguridad e implementos. Si falta algo, la fundación puede apoyar con lo necesario."
      ctaText="Quiero postular"
      ctaHref="#form"
      ctaVariant="primary"
    />
    <RainbowDivider />

    <FosterRequirements />
    <ProcessStepper steps={fosterSteps} eyebrow="EL PROCESO" heading="Así funciona el acogimiento" />
    <FosterPostular />
    <Footer />
  </main>
</BaseLayout>
