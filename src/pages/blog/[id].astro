---
import "../../styles/components/blog.css";
import { render, type CollectionEntry } from "astro:content";
import { Image } from "astro:assets";
import PageLayout from "../../layouts/PageLayout.astro";
import RainbowDivider from "../../components/RainbowDivider.astro";
import NextStepCta from "../../components/sections/NextStepCta.astro";
import { getReadingTimeLabel } from "../../utils/reading-time.ts";
import { SITE } from "../../config/site.ts";
import { getPublishedBlogPosts } from "../../utils/blog-content.ts";
import { buildSchemaGraph } from "../../utils/schema.ts";

export async function getStaticPaths() {
  const posts = await getPublishedBlogPosts();
  return posts.map((post: CollectionEntry<"blog">) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props as { post: CollectionEntry<"blog"> };
const { Content } = await render(post);
const dateFormatter = new Intl.DateTimeFormat("es-CL", { day: "numeric", month: "long", year: "numeric" });
const readingTimeLabel = getReadingTimeLabel(post.body);
const heroImageUrl = post.data.heroImage ? new URL(post.data.heroImage.src, SITE.siteUrl).href : undefined;
const schema = buildSchemaGraph({
  pageType: "blogPost",
  url: new URL(`/blog/${post.id}/`, SITE.siteUrl).href,
  title: post.data.title,
  description: post.data.description,
  publishDate: post.data.pubDate,
  authorName: post.data.author,
  featureImageUrl: heroImageUrl,
  category: post.data.category,
});
---

<PageLayout title={post.data.title} description={post.data.description} ogImage={heroImageUrl} schema={schema}>
  <article class="blog-post section-padding">
    <div class="container container--narrow">
      <a class="blog-post__top-link" href="/blog/">Volver al blog</a>
      <p class="eyebrow">BLOG</p>
      <h1>{post.data.title}</h1>
      <p class="blog-post__dek">{post.data.description}</p>
      <p class="blog-post__meta">
        {
          post.data.category && (
            <>
              <span class="blog-post__category">{post.data.category}</span>
              {" · "}
            </>
          )
        }
        Por <span class="blog-post__author">{post.data.author}</span>
        {" · "}
        <time datetime={post.data.pubDate.toISOString()}>{dateFormatter.format(post.data.pubDate)}</time>
        {" · "}
        {readingTimeLabel}
      </p>
      {
        post.data.heroImage && (
          <div class="blog-post__hero-wrap">
            <Image
              src={post.data.heroImage}
              alt={post.data.heroImageAlt ?? post.data.title}
              class="blog-post__hero"
              widths={[480, 768, 1200, 1600]}
              sizes="(min-width: 1024px) 920px, 100vw"
              quality={78}
            />
          </div>
        )
      }
    </div>
  </article>
  <RainbowDivider />
  <section class="section-padding blog-post__section">
    <div class="container container--narrow">
      <div class="blog-post__body">
        <Content />
      </div>
      <p class="blog-post__back">
        <a class="blog-post__back-link" href="/blog/"> Volver al blog </a>
      </p>
    </div>
  </section>
  <NextStepCta location="blog_post" />
</PageLayout>
