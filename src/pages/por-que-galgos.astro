---
import "../styles/components/page-hero.css";
import "../styles/components/stories.css";
import "../styles/components/por-que-galgos.css";
import { getCollection } from "astro:content";
import type { SharedGalleryPhoto } from "../scripts/shared-gallery";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import PageHero from "../components/PageHero.astro";
import SharedGalleryLightbox from "../components/SharedGalleryLightbox.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import WhyGalgosEditorial from "../components/sections/WhyGalgosEditorial.astro";
import CasesBand from "../components/sections/CasesBand.astro";
import NextStepCta from "../components/sections/NextStepCta.astro";
import { createResponsiveGalleryPhoto } from "../utils/responsive-gallery-images";
import { shuffle } from "../utils/shuffle";

const successDogs = (await getCollection("success-dogs")).filter((entry) => entry.data.gallery.length > 0);

const cases = await Promise.all(
  shuffle(successDogs)
    .slice(0, 3)
    .map(async (entry) => ({
      id: entry.id,
      name: entry.data.name,
      story: entry.data.story,
      instagramUrl: entry.data.instagramUrl,
      photos: await Promise.all(
        entry.data.gallery.map(async (img): Promise<SharedGalleryPhoto> => createResponsiveGalleryPhoto(img))
      ),
    }))
);
---

<BaseLayout
  title="Por qué galgos | Brigada Galgos"
  description="Por qué Brigada Galgos rescata, rehabilita y reubica específicamente galgos en Chile."
>
  <Navbar />
  <main id="main-content">
    <PageHero
      eyebrow="MÁS QUE UNA RAZA"
      h1="Por qué galgos"
      lead="No elegimos rescatar galgos por una preferencia de raza. Los elegimos porque vemos de cerca un abandono y una explotación que se repiten demasiado."
      leadBold="Rescatamos, rehabilitamos y reubicamos galgos en Chile para que puedan vivir, por fin, como los perros de familia que siempre merecieron ser."
    />

    <WhyGalgosEditorial />
    <CasesBand cases={cases} />
    <NextStepCta />
  </main>
  <Footer />
</BaseLayout>

<SharedGalleryLightbox ariaLabel="Galería de casos reales" />

<script>
  import "../scripts/init-shared-gallery";
</script>
