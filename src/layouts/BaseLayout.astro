---
import "../styles/global.css";
import { SITE } from "../config/site.ts";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = "/images/brigada-galgos-og-image.webp" } = Astro.props;
const { siteUrl, gtmContainerId, consentCookie } = SITE;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
---

<!doctype html>
<html lang="es" data-gtm-id={gtmContainerId} data-consent-cookie={consentCookie}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.ico" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CL" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:site_name" content="Brigada Galgos" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <slot name="head" />
  </head>
  <body>
    <slot />
    <div class="cookie-banner" id="cookie-banner" role="region" aria-live="polite" aria-label="Aviso de cookies">
      <div class="cookie-banner__inner container">
        <p class="cookie-banner__text">
          Usamos cookies de analítica para entender cómo se usa el sitio y mejorarlo. Puedes aceptar o rechazar su uso. <a
            href="/politica-de-cookies/"
            class="cookie-banner__link">Política de cookies</a
          >
        </p>
        <div class="cookie-banner__actions">
          <button class="btn btn--primary cookie-banner__button" id="cookie-accept" type="button">Aceptar</button>
          <button class="btn btn--ghost cookie-banner__button" id="cookie-reject" type="button">Rechazar</button>
        </div>
      </div>
    </div>
  </body>
</html>

<script>
  import "../scripts/cookie-consent";
</script>
