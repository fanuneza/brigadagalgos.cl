---
import "../styles/global.css";
import { SITE } from "../config/site.ts";
import { ClientRouter } from "astro:transitions";
import barlow700 from "@fontsource/barlow-condensed/files/barlow-condensed-latin-700-normal.woff2?url";
import barlow900 from "@fontsource/barlow-condensed/files/barlow-condensed-latin-900-normal.woff2?url";
import Seo from "@jdevalk/astro-seo-graph/Seo.astro";
import { buildStructuredDataGraph } from "../utils/structured-data";
import CookieBanner from "../components/sections/CookieBanner.astro";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  schema?: Record<string, any>;
}

const { title, description, ogImage = SITE.ogImagePath, schema } = Astro.props;
const { siteUrl, gtmContainerId, consentCookie, name } = SITE;
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = new URL(ogImage, siteUrl).href;
const logoUrl = new URL(SITE.logoPath, siteUrl).href;

const defaultSchema = buildStructuredDataGraph({
  canonicalUrl,
  title,
  description,
  imageUrl: ogImageUrl,
  logoUrl,
  pathname: Astro.url.pathname,
});
---

<!doctype html>
<html lang="es-CL" data-gtm-id={gtmContainerId} data-consent-cookie={consentCookie}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0FB0C9" data-theme-color />
    <link rel="preload" href={barlow700} as="font" type="font/woff2" crossorigin="anonymous" />
    <link rel="preload" href={barlow900} as="font" type="font/woff2" crossorigin="anonymous" />

    <Seo
      title={title}
      titleTemplate="%s | Brigada Galgos"
      description={description}
      canonical={canonicalUrl}
      ogType="website"
      ogImage={ogImageUrl}
      ogImageAlt={title}
      ogImageWidth={1200}
      ogImageHeight={630}
      siteName={name}
      locale="es_CL"
      graph={schema || defaultSchema}
      extraLinks={[
        {
          rel: "alternate",
          type: "application/rss+xml",
          title: `${name} | Blog`,
          href: new URL("feed.xml", siteUrl).href,
        },
        { rel: "sitemap", href: "/sitemap-index.xml" },
        { rel: "icon", href: "/favicon.ico", sizes: "any" },
        { rel: "icon", type: "image/png", sizes: "32x32", href: "/images/brigada-galgos-logo-32.png" },
        { rel: "icon", type: "image/png", sizes: "192x192", href: "/images/brigada-galgos-logo-192.png" },
        { rel: "apple-touch-icon", sizes: "180x180", href: "/images/brigada-galgos-logo-180.png" },
        { rel: "manifest", href: "/site.webmanifest" },
      ]}
    />
    <meta name="twitter:card" content="summary_large_image" />
    <slot name="head" />
    <ClientRouter />
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem("brigada-galgos-theme");
          if (t === "dark" || t === "light") document.documentElement.dataset.theme = t;
        } catch (e) {}
        var explicit = document.documentElement.dataset.theme;
        var dark = explicit ? explicit === "dark" : window.matchMedia("(prefers-color-scheme: dark)").matches;
        var meta = document.querySelector('meta[name="theme-color"][data-theme-color]');
        if (meta) meta.setAttribute("content", dark ? "#101217" : "#0FB0C9");
      })();
    </script>
  </head>
  <body>
    {
      gtmContainerId && (
        <noscript>
          <iframe
            src={`https://www.googletagmanager.com/ns.html?id=${gtmContainerId}`}
            height="0"
            width="0"
            style="display:none;visibility:hidden"
            title="Google Tag Manager"
          />
        </noscript>
      )
    }
    <a href="#main-content" class="skip-to-content">Saltar al contenido</a>
    <slot />
    <CookieBanner />
  </body>
</html>

<script>
  import "../scripts/cookie-consent";
  import "../scripts/analytics-events";
  import "../scripts/theme";
</script>
